LabTransport
agents:
	humans: Nurse, LabPersonnel
	robots: TransportRobot, RoboticArm
locations: PatientFloor, Laboratory
resources: Sample

Nurse:
	1: moveTo PatientFloor
	2: stop until position(TransportRobot, PatientFloor)
	3: deliver Sample

TransportRobot:
	1: moveTo PatientFloor
	2: receiveFrom Nurse
	3: moveTo Laboratory
	4: stop until !possess(TransportRobot, Sample)

RoboticArm:
	1: moveTo Laboratory
	2: stop until position(TransportRobot, Laboratory)
	3: receiveFrom TransportRobot
	4: deposit Sample

LabPersonnel:
	1: stop

success: possess(RoboticArm, Sample)
failure: time(120)
