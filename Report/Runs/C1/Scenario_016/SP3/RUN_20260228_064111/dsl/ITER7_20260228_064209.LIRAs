Service

agents:
	humans: ServiceUser
locations: room7002, elevator, room3201
resources: object

ServiceUser:
	1: pick serviceTask

serviceTask:
	1: moveTo room7002
	2: stop
	3: receiveFrom object
	4: moveTo elevator
	5: follow humans
	6: stop
	7: navigateOutOfElevator()
	8: navigateToServiceGoalLocation()
	9: waitForObjectCollectionAndConfirmation()
