pattern "Service Navigation" {
  inputs {
    input "current location" location
    input "service start location" location
    input "object to be transported" object
  }
  
  agent "agent1" {
    moveTo serviceStartLocation
      precondition "Current Location is Same as Service Start Location" {
        success "NAVIGATED"
      }
  }
  
  agent "agent2" {
    pick object
      precondition "Object is Placed in Basket" {
        success "OBJECT_IS_IN_BASKET"
      }
  }
  
  agent "agent3" {
    moveTo elevatorLocation
      precondition "Current Location is Same as Elevator Location" {
        success "NAVIGATED"
      }
  }
  
  agent "agent4" {
    stop floorLocation
      precondition "Current Location is Same as Floor Location" {
        success "ASKED"
      }
  }
  
  agent "agent5" {
    moveTo elevatorLocation
      precondition "Current Location is Same as Elevator Location" {
        success "NAVIGATED"
      }
  }
  
  agent "agent6" {
    stop floorLocation
      precondition "Current Location is Same as Floor Location" {
        success "ASKED"
      }
  }
  
  agent "agent7" {
    moveTo floorLocation
      precondition "Current Location is Same as Floor Location" {
        success "NAVIGATED"
      }
  }
  
  agent "agent8" {
    moveTo serviceGoalLocation
      precondition "Current Location is Same as Service Goal Location" {
        success "NAVIGATED"
      }
  }
  
  agent "global_agent" {
    deliver object
      precondition "Object is Collected and Service is Completed" {
        success "SERVICE_IS_COMPLETED"
      }
  }
}
