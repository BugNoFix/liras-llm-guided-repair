ServiceRobot

agents:
	humans: ServicePersonnel
locations: room7002, elevator, room3201
resources: objectToBeTransported

ServicePersonnel:
	1-4: moveTo room7002
	5: pick objectToBeTransported
	6-8: stop
	9: deliver objectToBeTransported

Robot:
	1: moveTo room7002
	2-3: patrol() until presence(ServicePersonnel)
	4-5: navigateToElevator()
	6-7: requestHumanAssistance()
	8-9: navigateToGoalLocation()
	10: waitForConfirmation()
