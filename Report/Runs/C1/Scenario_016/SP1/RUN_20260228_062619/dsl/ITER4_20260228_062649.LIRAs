Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4, room7002, elevator7thFloor, floor3rd
resources: water

Robot:
	1: moveTo l1
	   checkItems
	2: moveTo l2
	   checkItems
	3: moveTo l3
	   checkItems
	4: moveTo l4
	   checkItems
	5: skip if !presence(humans)
	6-8: colaborativeGrasping(water)
	9-12: moveTo 7002
	13-14: waitForHuman()
	15-18: moveTo 7thFloorElevator()
	19-22: askForHumanAssistance()
	23-26: moveTo ThirdFloor()
	27-30: askForHumanAssistance()
	31-34: moveOutOfElevator()
	35-38: moveToServiceGoalLocation()

Human:
	1-4: moveTo l4
	5-8: waitForRobotGrasping(water)
	9-12: collectObject()
	13-16: getServiceCompletionConfirmation()
