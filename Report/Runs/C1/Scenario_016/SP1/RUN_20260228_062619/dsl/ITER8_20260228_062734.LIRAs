Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4, room7002, elevator7thFloor, floor3rd
resources: water

Robot:
	1: moveTo l1
	2: stop
	3: moveTo l2
	   stop checkItems
	4: moveTo l3
	   checkItems
	5: moveTo l4
	   checkItems
	6: skip if !presence(humans)
	7-9: colaborativeGrasping(water)
	10-13: moveTo 7002
	14-15: waitForHuman()
	16-19: moveTo 7thFloorElevator()
	20-23: askForHumanAssistance()
	24-27: moveTo ThirdFloor()
	28-31: askForHumanAssistance()
	32-35: moveOutOfElevator()
	36-39: moveToServiceGoalLocation()

Human:
	1-4: moveTo l4
	5-8: waitForRobotGrasping(water)
	9-12: collectObject()
	13-16: getServiceCompletionConfirmation()
