Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4
resources: water

Robot:
	1: moveTo l1
	2: fetch water
	3: moveTo l2
	4: fetch water
	5: moveTo l3
	6: fetch water
	7: moveTo l4
	8: fetch water
	9: skip if !presence(humans)
	   colaborativeGrasping(water)

Human:
	1-4: moveTo l4
	5:  colaborativeGrasping(water)

Laboratory

agents:
	nurses: Nurse
	robots: Robot
locations: lab, patientFloors
resources: samples

Nurse:
	1-4: moveTo patientFloors
	5: collectSample(barcode)
	6: enterDataInTrackSystem()
	7: moveTo lab
	8: deliveryRequest(samples)

Robot:
	1: moveTo lab
	2: pickUpSamples()
	3: scanBarcode()
	4: sortSamples()
	5: loadSamplesIntoModule()
	6: securelyLogDeliveryInformation()
	7: trackTimeBetweenSampleCollectionAndDelivery()

samples:
	1: moveTo lockedDrawer()
	2: authorizedPersonnelOrRobotOnlyOpenLockedDrawer()
	3: roboticArmPicksUpSample()
	4: scanBarcode()
	5: sortSamples()
	6: loadSamplesIntoModule()
	7: securelyLogDeliveryInformation()
	8: trackTimeBetweenSampleCollectionAndDelivery()
