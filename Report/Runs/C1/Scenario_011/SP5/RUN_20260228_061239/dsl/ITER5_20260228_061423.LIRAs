pattern TransportSamplesToLaboratory:
  inputs {
    barcode: string required
    nurse_id: string required
    lab_location: string required
    time: string
    samples: string
  }

  agent agent1 {
    deliver Laboratory with barcode: $input.barcode with nurse_id: $input.nurse_id with lab_location: $input.lab_location
    then stop // "Log Sample Collection" as invented action
    then condition "Sample Collected" with barcode: $input.barcode with nurse_id: $input.nurse_id
  }

  agent agent2 {
    pick Sample from "Locked Drawer" with barcode: $input.barcode with location: "locked drawer"
    then condition "Barcode Scanned" with barcode: $input.barcode // "Scan Barcode" as condition
    then stop with samples: $input.samples // "Sort Samples"
    then deposit Samples into "Entry Module" with samples: $input.samples // "Load Samples into Entry Module"
  }

  stop // "Log Sample Delivery"
  then condition "Sample Delivered" with barcode: $input.barcode with lab_location: $input.lab_location

  stop with time: $input.time // "Track Time between Sample Collection and Delivery"
}
