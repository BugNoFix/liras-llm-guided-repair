PatternNamePlaceholder
agent: agent1 moveTo Lab
agent: agent2 deliver Lab
sequence 1:
  sub-sequence 1:
    actions:
      - MoveTo(PatientFloor)
      - CollectSample()
    conditions:
      - BarcodePresent(sample)
  sub-sequence 2:
    actions:
      - InsertDataInTrackSystem(sample)
    conditions:
      - SampleReadyForCollection()
  sub-sequence 3:
    actions:
      - SecureLockedDrawerOpen(sample)
    conditions:
      - AuthorizedPersonnelOrRobotInLocation(Lab)
    continuation: DeliveryToLab()
sequence 2:
  sub-sequence 1:
    actions:
      - PickSampleFromDrawers()
    conditions:
      - BarcodePresent(sample)
    synchronizations:
      - LabPersonnelPickupSample()
  sub-sequence 2:
    actions:
      - AnalyzeSample()
    conditions:
      - SampleReadyForAnalysis()
    continuation: SaveAnalysisResults()
