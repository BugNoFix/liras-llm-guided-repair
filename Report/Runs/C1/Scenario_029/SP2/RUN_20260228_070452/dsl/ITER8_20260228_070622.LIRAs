Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4
resources: water

Robot:
	1: moveTo l1
	2: stop
	3: moveTo l2
	4: stop
	5: moveTo l3
	6: stop
	7: moveTo l4
	8: stop
	9: skip if !presence(humans)
	10: speak(story)
	11: askQuestion
	12: listen(response)
	13: continueStory(response)
	14: deliverBooks(books)
	15: coordinateWithNurse()

Human:
	1-4: moveTo l4
	5:  colaborativeGrasping(water)
