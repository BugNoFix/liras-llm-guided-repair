Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4
resources: water

Robot:
	1: moveTo l1
	2: stop
	3: moveTo l2
	   stop
	4: moveTo l3
	   checkItems
	5: moveTo l4
	   checkItems
	6: skip if !presence(humans)
	7: speak(story)
	8: askQuestion
	9: listen(response)
	10: continueStory(response)
	11: deliverBooks(books)
	12: coordinateWithNurse()

Human:
	1-4: moveTo l4
	5:  colaborativeGrasping(water)
