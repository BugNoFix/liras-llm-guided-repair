Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4
resources: water

Robot:
	1: moveTo l1
	2: stop
	3: moveTo l2
	4: stop
	5: moveTo l3
	   stop
	6: moveTo l4
	   checkItems
	7: skip if !presence(humans)
	8: speak(story)
	9: askQuestion
	10: listen(response)
	11: continueStory(response)
	12: deliverBooks(books)
	13: coordinateWithNurse()

Human:
	1-4: moveTo l4
	5:  colaborativeGrasping(water)
