Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4
resources: water

Robot:
	1: moveTo l1
	2: stop
	3: moveTo l2
	4: stop
	5: moveTo l3
	6: stop
	7: moveTo l4
	   stop
	8: skip if !presence(humans)
	9: speak(story)
	10: askQuestion
	11: listen(response)
	12: continueStory(response)
	13: deliverBooks(books)
	14: coordinateWithNurse()

Human:
	1-4: moveTo l4
	5:  colaborativeGrasping(water)
