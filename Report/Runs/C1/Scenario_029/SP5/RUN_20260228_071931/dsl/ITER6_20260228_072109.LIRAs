pattern:
  name: RobotTherapySession
  agents:
    Robot:
      l1 "Tell a story"
      parameter "Child's name"
    Nurse:
      l1 "Pause session"
  success:
    condition "Robot.hasToldStory() && Nurse.hasPausedSession()"
  failure:
    condition "Robot.hasNotToldStory() || Nurse.hasNotPausedSession()"
  actions:
    TellStory:
      body "Robot.tellStory(child.name)"
      description "Tell a story to the child"
    PauseSession:
      body "Nurse.pauseSession()"
      description "Pause the session"
    CoordinateBookDelivery:
      body "AutonomousCart.deliverBooks()"
      description "Coordinate book delivery"
