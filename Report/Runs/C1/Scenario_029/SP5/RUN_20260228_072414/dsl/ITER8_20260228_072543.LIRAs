ChildTherapy

agents:
	humans: Child, Parent
	robots: TherapyBot
locations: therapyArea
resources: book, story

TherapyBot:
	1-5: moveTo therapyArea
	6: moveTo Parent
	7: follow Child
	8: receiveFrom Child
	9: deliver story
	10: askIfWantBook(Child)
	11: deliverBook(Child)

Parent:
	1-5: patrol(therapyArea) until start()
	6: coordinate(TherapyBot, Child)

Child:
	1-3: moveTo TherapyBot
	4-7: interactWithBot(TherapyBot)
	8-9: decideIfWantBook()
	10-11: receiveBook(TherapyBot)
