Supermarket

agents:
	humans: Parent
	robots: Robot
locations: l1, l2, l3, l4
resources: water, books

Robot:
	1: moveTo l1
	2: fetch books
	3: moveTo l2
	4: fetch books
	5: moveTo l3
	6: fetch books
	7: moveTo l4
	   fetch books
	8: skip if !presence(parents)
	   engage(children, books)
	9: deliverBooks(books)

Parent:
	1-4: moveTo l4
	5: coordinate(start, pause, stop)

Robot:
	1-3: moveTo l1
	   askSimpleQuestion(child)
	2-3: engage(child, books)
	4: deliverBooks(books)

Child:
	1-3: engage(robot, books)
	4: narrate(story)

Nurse:
	1-4: moveTo l4
	5: coordinate(start, pause, stop)

Robot:
	1-3: moveTo l1
	   askSimpleQuestion(parent)
	2-3: engage(parent, books)
	4: deliverBooks(books)

Parent:
	1-4: moveTo l4
	5: coordinate(start, pause, stop)
