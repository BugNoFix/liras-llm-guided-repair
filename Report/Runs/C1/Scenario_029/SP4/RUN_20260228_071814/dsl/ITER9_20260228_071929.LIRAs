NurseAssistant

agents:
	humans: Child, Parent
	robots: Robot, BookCart
locations: chemotherapyWard, reservedArea
resources: books

Robot:

1-5: moveTo chemotherapyWard

Child:
	1-3: stop
	4: stop

Parent:
	1-2: deliver bookCart
	3-4: stop

BookCart:
	1-5: moveTo chemotherapyWard until arriveAt(Robot)
	deliverBooks()

Child:
	1-3: shapeNarrative()
	4: pause()

Parent:
	1-2: collaborativeUnload(bookCart)
	3-4: stop()
