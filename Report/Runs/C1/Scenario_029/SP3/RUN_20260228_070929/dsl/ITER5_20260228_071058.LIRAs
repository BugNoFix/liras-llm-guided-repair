Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4
resources: water

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4
	5: colaborativeGrasping(water)

Human:
	1-4: moveTo l4
	5:  colaborativeGrassping(water)

Robot:
	1: moveTo therapyArea
	2: engageWithChildren()
	3: interactWithChildUsingVoiceBasedDialogue()
	4: deliverBooksViaAutonomousCart()
	5: coordinatedByNurse(start, pause, stop)

engageWithChildren():
	1: tellStories()
	2: askSimpleQuestionsToLetChildrenShapeNarrative()

interactWithChildUsingVoiceBasedDialogue():
	1: recognizeChildsVoice()
	2: respondToChildsQuery()

deliverBooksViaAutonomousCart():
	1: coordinatedDeliveries()

coordinatedByNurse(start, pause, stop):
	1: startTherapySession()
	2: pauseTherapySession()
	3: stopTherapySession()
