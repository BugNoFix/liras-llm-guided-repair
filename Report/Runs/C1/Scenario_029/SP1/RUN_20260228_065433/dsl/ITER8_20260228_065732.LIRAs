name Therapy
input {
  agents: [A1, A2, ..., An],
  locations: [L1, L2, ..., Lm],
  resources: [R1, R2, ..., Rn]
}

sequence {
  if (SoC(A1)) {
    moveTo L1
    ask A1 "What is your favorite animal?"
    wait A1 "response"
  }
  
  subSequence {
    moveTo L2
    ask A1 "Why do you like that animal?"
    wait A1 "response"
  } until (weight(R1) > 0.5)
  
  subSequence {
    moveTo L3
    coordinated A2 deliverBooks R2
    wait A2 "bookDelivery"
  } until (weight(R2) > 0.5)
  
  if (pause(A1)) {
    wait A1 "pauseEnd"
  }
}

conclusion {
  all(subSequence)
  weight(R1) > 0.8
}
