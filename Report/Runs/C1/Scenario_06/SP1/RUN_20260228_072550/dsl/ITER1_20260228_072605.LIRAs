hotel_butler :
name "Hotel Butler";
location starting_point;
resources storage_box;
agents guests;

pattern delivery {
name "Delivery Pattern";
actions moveToGuestLocation(location), openStorageBox(), requestPINCode();
sub-sequences {
1 { actions deliverItem(item), closeStorageBox(); }
2 { actions wait(5), then(2); }
}
conclusion {
actions stop();
}
}

action moveToGuestLocation(location) {
conditions distance(robot, location) < 10;
actions move(robot, location);
}

action openStorageBox() {
conditions storage_box.isOpen();
actions openStorageBox();
}

action requestPINCode() {
conditions storage_box.hasItem();
actions requestPINCode();
}

action deliverItem(item) {
conditions item.match("guest_request");
actions deliverItem(item);
}

action closeStorageBox() {
conditions storage_box.isOpen();
actions closeStorageBox();
}

action wait(n) {
wait(n);
}

action stop() {
stop();
}

agent guests {
name "Guest";
location guest_location;
resources item;
}

environment hotel {
location starting_point, lifts;
}
}
