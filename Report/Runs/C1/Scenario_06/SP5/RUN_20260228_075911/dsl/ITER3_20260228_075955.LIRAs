HotelButler

Inputs:
  Guest_PIN_code: String
  Item_Type
  Item_Quantity

Agents:
  Butler: mobile_robotic_base secure_storage_box built_in_map sensor_data

Actions:
  navigate_to_guest: Butler moveTo guest_location
  allow_storage_access: Butler allow_access_to secure_storage_box with Guest_PIN_code
  deliver_item: Butler deliver Item_Type quantity Item_Quantity from secure_storage_box to guest_location

Success:
  guest_receives_item_successfully

Failure:
  guest_enters_incorrect_PIN_code or secure_storage_box_is_not_accessible
