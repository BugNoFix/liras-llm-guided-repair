Drone_Delivery_Pattern

agents:
    robots: Drone1, Drone2
    humans: Human

locations: currentLocation, serviceStartLocation, elevatorLocation7thFloor, elevatorLocation3rdFloor, goalLocationRoom3201
resources: basket

Drone1:
    1: moveTo currentLocation
    stop
    moveTo serviceStartLocation
    stop
    moveTo elevatorLocation7thFloor
    stop
    stop
    stop
    moveTo goalLocationRoom3201
    stop

Human:
    1: deposit basket
