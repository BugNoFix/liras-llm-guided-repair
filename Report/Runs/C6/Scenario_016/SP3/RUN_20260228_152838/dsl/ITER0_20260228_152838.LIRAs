Service

agents:
	humans: ServiceUser
locations: room7002, elevator, room3201
resources: object

ServiceUser:
	1-9: performTask(serviceTask) until !isCompleted(serviceTask)

serviceTask:
	1: navigateTo(room7002)
	2: waitForObject()
	3: confirmObjectPlacedInBasket()
	4: navigateToElevator()
	5: askForHumanAssistanceToTakeElevator()
	6: confirmFloorReached()
	7: navigateOutOfElevator()
	8: navigateToServiceGoalLocation()
	9: waitForObjectCollectionAndConfirmation()
