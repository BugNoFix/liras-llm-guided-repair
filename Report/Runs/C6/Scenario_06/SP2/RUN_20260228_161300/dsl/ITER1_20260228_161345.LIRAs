HotelButler

agents:
	humans: Guest
	robots: Butler

locations: lobby, rooms
resources: item1, item2

Butler:
	1: moveTo lobby until position(Guest, lobby)
	2-4: pick item1
	5: deposit item1
	6: moveTo rooms
	7-8: moveTo rooms until position(Guest, rooms)
	9-10: deliver item1
	11: deposit item1

Guest:
	1-4: moveTo rooms
	5-7: stop
	8-10: receiveFrom Butler
