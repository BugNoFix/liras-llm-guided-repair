Hotel_Robot_Butler

agents:
	humans: Guest
	robots: Hotel_Robot_Butler
locations: lobby, rooms
resources: items

Guest:
	1-4: moveTo lobby
	5: stop
	6: moveTo rooms
	7: stop
	8: pick items
	9: stop

Hotel_Robot_Butler:
	1: moveTo lobby
	2: pick items
	3: moveTo rooms
	4: follow Guest
	5: stop
	6: deliver items
	7: stop
	8: moveTo lobby
