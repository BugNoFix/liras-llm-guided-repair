ChemotherapyWard

agents:
	humans: child, parent, Nurse
	robots: Robot, Cart

locations: chemotherapyArea
resources: book

Robot:
	1: moveTo chemotherapyArea
	2: follow child
	3: pick book
	4: follow Nurse

Nurse:
	1: stop
	2: stop

child:
	1: follow Robot
	2: stop

parent:
	1: receiveFrom Robot
	2: stop

Cart:
	1: moveTo chemotherapyArea
	2: deliver book
