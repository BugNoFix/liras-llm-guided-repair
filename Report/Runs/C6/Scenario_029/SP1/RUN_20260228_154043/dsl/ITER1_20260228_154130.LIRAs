ChemotherapyRobot

agents:
	humans: Child, Parent, Nurse
	robots: Robot, BooksCart

locations: chemoTherapyArea
resources: books

Robot:
	1: moveTo chemoTherapyArea
	6: follow Child
	9: stop
	13: deliver books
	18: stop

Parent:
	1: moveTo Child
	5: receiveFrom Robot
	8: stop

Child:
	1: follow Robot
	5: receiveFrom Robot
	8: stop

Nurse:
	1: stop
	4: stop
	7: stop

