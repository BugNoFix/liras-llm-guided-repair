ChildTherapy

agents:
	humans: Child, Parent
	robots: TherapyBot

locations: therapyArea
resources: book, story

TherapyBot:
	1-5: moveTo therapyArea
	6: moveTo Parent
	7: stop
	8: stop
	9: stop
	10: stop
	11: deliver book

Parent:
	1-5: moveTo therapyArea
	6: follow TherapyBot

Child:
	1-3: moveTo TherapyBot
	4-7: follow TherapyBot
	8-9: stop
	10-11: receiveFrom TherapyBot
