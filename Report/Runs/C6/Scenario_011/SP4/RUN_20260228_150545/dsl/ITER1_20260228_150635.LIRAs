NurseAssistant

agents:
    humans: Nurse
    robots: LabAssistant, LabRobot, LabAnalysisMachine

locations: patientFloor, labRoom
resources: barcodeScanner, lockedDrawers, sample

Nurse:
    1: stop
    2: stop
    6: stop

LabAssistant:
    1: moveTo patientFloor
    2: stop
    5: pick sample
    6: deposit sample
    8: moveTo patientFloor

LabRobot:
    1: moveTo labRoom
    5: pick sample
    6: moveTo patientFloor

LabAnalysisMachine:
    1: pick sample
    5: deposit sample
