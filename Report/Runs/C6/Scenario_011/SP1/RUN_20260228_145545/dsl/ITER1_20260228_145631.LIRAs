SampleTransportation

agents:
	humans: Nurse, LaboratoryPersonnel
	robots: RobotArm

locations: patientFloor, laboratory
resources: sample, entryModule

Nurse:
	1: pick sample
	4: stop
	5: moveTo laboratory

LaboratoryPersonnel:
	1: moveTo laboratory
	3: stop
	4: stop
	6: deposit entryModule

RobotArm:
	1: moveTo patientFloor
	2: moveTo patientFloor
	4: stop
	5: pick sample
	6: stop
	7: moveTo laboratory
	9: stop
	10: deposit entryModule
