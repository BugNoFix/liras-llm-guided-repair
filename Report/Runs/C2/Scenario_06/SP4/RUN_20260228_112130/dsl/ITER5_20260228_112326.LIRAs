Hotel

agents:
	robots: HotelRobot
locations: lobby, rooms
resources: storageBox, items

HotelRobot:
	1: moveTo lobby
	pick items
	2: moveTo room
	deposit items
	3: moveTo lobby
	pick storageBox
	4: moveTo room
	   checkItems
	5: grantAccess(storageBox, personalPINCode)
	6: skip if !presence(guests)
	7: deliver(items)

Lobby

agents:
	butlers: HotelRobot
locations: lobby, rooms
resources: storageBox, items

Rooms

agents:
	guests: Human
locations: rooms
resources: items

Butler:
	1-4: moveTo lobby
	5: moveTo room
	6: checkItems
	7: grantAccess(storageBox, personalPINCode)
	8: deliver(items)

Lift:
	1: moveTo lobby
	2: moveTo rooms

Guest:
	1-4: moveTo room
	5: checkItems
	6: enterPersonalPINCode(storageBox)
	7: grantAccess(storageBox, personalPINCode)
	8: takeDeliveredItems()

Storage Box:
	name: storageBox
	type: SecureStorageBox

Items:
	name: items
	type: DeliverableItem

PersonalPINCode:
	name: personalPINCode
	type: SecurePassword

Lobby:
	location: Lobby
	agents: butlers, guests
	resources: storageBox, items

Rooms:
	location: Rooms
	agents: guests
	resources: items

Hotel:
	location: Hotel
	agents: butlers, guests
	resources: storageBox, items

Lift:
	location: Lobby, Rooms
	agents: lift
	resources: none

SecureStorageBox:
	name: storageBox
	type: SecureStorageBox

DeliverableItem:
	name: items
	type: DeliverableItem

PersonalPINCode:
	name: personalPINCode
	type: SecurePassword

GrantAccess:
	name: grantAccess
	type: Action

TakeDeliveredItems:
	name: takeDeliveredItems
	type: Action
