HotelButler

agents:
	robots: HotelButler
locations: lobby, rooms, storageBox, elevators

HotelButler:
	1: moveTo lobby
	2: moveTo rooms
	3: enterLobby
	4: moveTo storageBox
	   checkItems
	5: unlockStorageBox()
	6: deliver(items)
	7: moveTo elevators
	8: operateElevators()
	9: returnToLobbry()

Elevators:
	1-4: moveTo lobby
	5: operate()

storageBox:
	1-4: moveTo lobby
	5: checkItems
	6: unlock()
	7: deliver(items)
	8: returnToLobbry()
