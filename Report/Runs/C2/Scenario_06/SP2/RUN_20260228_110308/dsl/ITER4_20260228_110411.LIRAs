HotelButler

agents:
	humans: Guest
	robots: Butler
locations: lobby, rooms
resources: item1, item2

Butler:
	1: moveTo lobby until position(Guest, lobby)
	2-4: pick item1
	5: deposit item1
	6: deposit item2
	7-8: navigate(rooms) until presence(Guest)
	9-10: allowAccess(roomNumber) until PINCode(Guest)
	11: unload(storageBox)

Guest:
	1-4: moveTo roomNumber
	5-7: enterPINCode(roomNumber)
	8-10: receiveItem
