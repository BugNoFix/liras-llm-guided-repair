Hotel_Robot_Butler

agents:
	guests: Guest_01
	robots: Hotel_Robot_Butler
locations: lobby, rooms
resources: items

Guest_01:
	1-4: moveTo lobby
	5: enterPINCode(storageBox)
	6: moveTo room
	7: openStorageBox()
	8: takeItem()
	9: closeStorageBox()

Hotel_Robot_Butler:
	1: moveTo lobby
	2: navigateLifts()
	3: moveTo room
	4: locate(guest)
	5: allowAccess(storageBox, guest)
	6: deliverItem()
	7: closeStorageBox()
	8: returnToLobby()
