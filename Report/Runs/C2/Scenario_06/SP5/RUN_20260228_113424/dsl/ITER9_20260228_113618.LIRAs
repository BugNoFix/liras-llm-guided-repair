HotelButler

agents:
	humans: Guest
	robots: Butler
locations: lobby, room1, room2, storage_box
resources: item

Guest:
	1-5: deposit item
	6: stop
	7: receiveFrom Butler

Butler:
	1-3: patrol(lobby, room1, room2, ...) until !hasItem()
	4-5: moveTo guest
	6-7: allowAccess(storage box)
	8: skip if itemAlreadyDelivered(room number)
	9-10: deliver(item)
	11: moveTo lobby
