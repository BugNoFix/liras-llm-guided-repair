HotelButler

agents:
	humans: Guest
	robots: HotelRobot
locations: lobby, room1, room2
resources: item

Guest:
	1-5: receiveFrom HotelRobot
	6-7: moveTo roomNumber
	8: skip if position(HotelRobot, room1)
	9: stop

HotelRobot:
	1-3: follow Guest until position(Guest, room1)
	4: moveTo Guest
	5-6: deliver item
	7: skip if isDelivered(item) || isAtLocation(roomNumber)

HotelRobot:
	1-3: navigate(lobby, room1, room2, ...) using map
	4-6: stop until at(location)
	7-8: deliver(item)
	9-10: skip if isDelivered(item) || isAtLocation(roomNumber)
