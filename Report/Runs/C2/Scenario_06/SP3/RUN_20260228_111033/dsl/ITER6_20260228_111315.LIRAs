Hotel

agents:
	robots: HotelRobot, guest
locations: lobby, rooms
resources: storageBox, items

HotelRobot:
	1-5: moveTo lobby
	6: checkItems
	7: moveTo room (n)
	8: checkPresence(guest)
	9: grantAccess(storageBox)
	10: deliver items to guest

Lobby

agents:
	butlers: HotelRobot
locations: lobby
resources: none

Room

agents:
	guests: Human
locations: room (n)
resources: none

Butler:
	1-5: moveTo lobby
	6: checkItems
	7: moveTo room (n)
	8: checkPresence(guest)
	9: grantAccess(storageBox)
	10: deliver(items, guest)

Lift:
	1-3: moveTo lobby
	4: moveTo room (n)

Items:
	1-10: placeInStorageBox
	11: moveTo deliveryLocation (n)

Presence:
	1-5: moveTo lobby
	6: checkPresence(guest)

Access:
	1-5: moveTo storageBox
	6: grantAccess(storageBox)

Delivery:
	1-3: moveTo deliveryLocation (n)
	4: deliver(items, guest)
