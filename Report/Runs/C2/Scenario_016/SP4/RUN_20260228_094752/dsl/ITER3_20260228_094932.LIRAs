ServicePattern

agents:
    humans: Human
    robots: Robot

locations:
    room7002,
    elevator7thFloor,
    elevator3rdFloor,
    room3201

resources:
    object

Robot:
    1: moveTo room7002
    pick object
    2: moveTo elevator7thFloor
    3: moveTo elevator3rdFloor
    4: moveTo room3201
    deposit object

Human:
    1: deliver object Robot
    2: moveTo elevator7thFloor
    3: moveTo elevator3rdFloor
    4: pick object
