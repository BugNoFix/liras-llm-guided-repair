ServiceAssistant

agents:
	humans: ServiceUser
	robots: Robot
locations: room7002, elevator, room3201
resources: basket, object

Robot:

1: moveTo room7002
2-3: stop
4: moveTo elevator
5-6: stop
7: stop
8-9: stop until confirmation()
10: moveOutsideElevator
11: moveTo room3201
12: waitForHuman(ServiceUser) until confirmation()
13: serviceGoalAccomplished()

ServiceUser:

1-4: moveTo room7002
5-6: putObjectInBasket()
7: moveTo elevator
8-9: rideElevator(room3201) until confirmation()
10: moveTo room3201
11-12: collectObjectAndConfirmServiceCompletion()
