agents {
  Drone1,
  Drone2,
  Human
}

locations {
  currentLocation,
  serviceStartLocation,
  elevatorLocation7thFloor,
  elevatorLocation3rdFloor,
  goalLocationRoom3201
}

resources {
  basket
}

pattern {
  Drone1 -> moveTo(currentLocation)
  Drone1 -> waitFor(Human)
  Human -> putObjectInBasket()
  Drone1 -> moveTo(serviceStartLocation)
  Drone1 -> waitForConfirmation()
  Drone1 -> moveTo(elevatorLocation7thFloor)
  Drone1 -> askForHumanAssistance()
  Drone1 -> moveInsideElevator()
  Drone1 -> askForHumanAssistance()
  Drone1 -> moveTo(goalLocationRoom3201)
  Drone1 -> waitForHumanCollection()
}
