Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4, room7002, seventh_floor_elevator, third_floor, room3201
resources: none

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	   stop
	4: moveTo l4
	   checkItems
	5: skip if !presence(humans)
	6: moveTo 7002
	   waitForHuman()
	7: moveTo elevator()
	   askForHumanAssistance()
	8: moveTo floor()
	   askForHumanAssistance()
	9: moveTo goalLocation()
	   waitForHuman()
	10: finishService()

Human:
	1-4: moveTo l4
	5:  colaborativeGrasping(none)
