ServiceRobot

agents:
	humans: ServicePersonnel
locations: room7002, elevator, room3201
resources: objectToBeTransported

ServicePersonnel:
	1-4: moveTo room7002
	5: receiveFrom objectToBeTransported
	6-8: stop
	9: pick objectToBeTransported

Robot:
	1: moveTo room7002
	2-3: stop until position(ServicePersonnel, room7002)
	4-5: moveTo elevator
	6-7: stop
	8-9: navigateToGoalLocation()
	10: waitForConfirmation()
