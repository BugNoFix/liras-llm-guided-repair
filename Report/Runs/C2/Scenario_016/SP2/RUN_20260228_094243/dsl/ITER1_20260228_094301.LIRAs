ServiceBot

agents:
	humans: ServiceUser
locations: room7002, elevator, room3201
resources: object, confirmation

ServiceUser:
	1-5: moveTo room7002
	6-8: receiveFrom ServiceBot object
	9-10: getConfirmation()

moveTo room7002:
	1: move(room7002)
	2-3: stop
	4: moveTo ServiceBot

waitForObject():
	1: moveTo basket()
	2-3: waitForHuman()
	4: confirmationReceived()

moveTo elevator:
	1: move(elevator)
	2-3: stop
	4: moveTo ServiceBot

askForHumanAssistance():
	1: moveTo human()
	2-3: askForHelp()
	4: getConfirmation()

moveInsideElevator():
	1: move(elevator)
	2-3: stop
	4: moveTo ServiceBot

askForHumanAssistanceToKnowCorrectFloor():
	1: moveTo human()
	2-3: askForHelp()
	4: getConfirmation()

moveOutsideElevator():
	1: move(room3201)
	2-3: stop
	4: moveTo ServiceBot

waitForHumanToCollectObjectAndGetServiceCompletionConfirmation():
	1: moveTo room3201()
	2-3: waitForHuman()
	4: confirmationReceived()

getConfirmation():
	1: moveTo ServiceBot()
	2-3: getConfirmation()
	4: stop

moveToServiceGoalLocation(room3201):
	1: move(room3201)
	2-3: stop
	4: moveTo ServiceBot

waitForHumanToCollectObjectAndGetServiceCompletionConfirmation():
	1: moveTo room3201()
	2-3: waitForHuman()
	4: confirmationReceived()
