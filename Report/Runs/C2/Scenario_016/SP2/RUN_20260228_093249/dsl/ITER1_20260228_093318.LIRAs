Robot_Navigation_Pattern
# Task 1: Navigate from current location to service start location (room 7002)

seq1 = moveTo(location=7002, agents=[currentAgent])

# Task 2: Wait for human to put the object to be transported in basket, and get confirmation.

seq2 = waitForHumanAction(agent=currentAgent, predicate=SoC(human)), moveTo(location=7002)

# Task 3: Navigate from room 7002 to the 7th floor elevator.

seq3 = moveTo(location=7002), navigateToElevator(floor=7)

# Task 4: Ask for human assistance to take the elevator to the 3rd floor.

seq4 = askForHumanAssistance(agent=currentAgent, predicate=weight(object)), moveToElevator(floor=3)

# Task 5: Navigate inside the elevator.

seq5 = navigateInsideElevator()

# Task 6: Ask for human assistance to know when correct floor is reached.

seq6 = askForHumanAssistance(agent=currentAgent, predicate=SoC(human)), waitForHumanAction(agent=currentAgent, predicate=weight(object))

# Task 7: Navigate out of the elevator.

seq7 = moveToElevator(floor=3), navigateOutsideElevator()

# Task 8: Navigate from the 3rd floor elevator to service goal location (room 3201).

seq8 = moveTo(location=3201)

# Task 9: Wait for human to collect object and get service completion confirmation.

seq9 = waitForHumanAction(agent=currentAgent, predicate=SoC(human)), moveTo(location=3201)
