Robot_Therapy_Session

agents:
    robots: bot1:bot2
    humans: human1

locations:
    child_area,
    control_station,
    book_pickup_point,
    delivery_point

resources:
    story_content,
    books

bot1:
    1: moveTo child_area
    2: deliver story_content child_area

human1:
    1: moveTo control_station
    2: stop

bot2:
    1: fetch books book_pickup_point
    2: moveTo delivery_point
    3: deliver books delivery_point
