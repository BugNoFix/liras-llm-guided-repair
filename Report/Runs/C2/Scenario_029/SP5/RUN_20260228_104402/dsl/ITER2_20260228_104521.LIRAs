Robot_Therapy_Session

agents:
    Robot: robots
    AutonomousCart: robots
    Nurse: humans

locations:
    child_area,
    control_station,
    book_pickup_point,
    delivery_point

resources:
    story_content,
    books

Robot:
    1: moveTo child_area
    2: deliver story_content child_area

Nurse:
    1: moveTo control_station
    2: stop

AutonomousCart:
    1: fetch books book_pickup_point
    2: moveTo delivery_point
    3: deliver books delivery_point
