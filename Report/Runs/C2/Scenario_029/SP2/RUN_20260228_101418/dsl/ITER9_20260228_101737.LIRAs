ChemoBot


locations:
    TherapyArea

resources:


Robot:
    1: moveTo TherapyArea
    3: EngageWithChild(child)
        Continuation: IfSoC(Child), Then ExecuteAction(InteractVoice());
        Else ExecuteAction(CoordinateBookDelivery());
        EndIf;
    6: Pause()
        Continuation: IfSoC(Nurse), Then ExecuteAction(SendCommands());
        Else ExecuteAction(RobotFree());
        EndIf;
