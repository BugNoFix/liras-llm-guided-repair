Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4
resources: water, books

Robot:
	1: moveTo l1
	   
	2: moveTo l2
	   
	3: moveTo l3
	   
	4: moveTo l4
	   stop
	5: skip if !presence(humans)
	   interact(children)
	6: move cart l4 to l1
	7: books(cart, l1)
	8: pause
	9: move cart l2 to l3
	10: interact(parents)
	11: move cart l3 to l4
	12: deliver(books, l4)
	13: endSession

Human:
	1-4: moveTo l4
	5: coordinate(start, pause, stop)

Robot:
	1-8: interact(children)
	9-12: deliver(books, l4)

Cart:
	1-3: move cart l1 to l4
	4-6: move cart l2 to l3

Interact:
	1: askSimpleQuestions(children)
	2: letChildrenShapeNarrative(children)

Coordinate:
	1: sendStartCommand()
	2: sendPauseCommand()
	3: sendStopCommand()
