Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4
resources: water, books

Robot:
	1: moveTo l1
	   
	2: moveTo l2
	   
	3: moveTo l3
	   
	4: moveTo l4
	   
	5: skip if !position(humans, l4)
	6: call Interact
	7: move cart l4 to l1
	8: books(cart, l1)
	9: pause
	10: move cart l2 to l3
	11: interact(parents)
	12: deliver books l4
	13: endSession

Human:
	1-4: moveTo l4
	5: coordinate(start, pause, stop)

Robot:
	1-8: interact(children)
	9-12: deliver(books, l4)

Cart:
	1-3: move cart l1 to l4
	4-6: move cart l2 to l3

Interact:
	1: askSimpleQuestions(children)
	2: letChildrenShapeNarrative(children)

Coordinate:
	1: sendStartCommand()
	2: sendPauseCommand()
	3: sendStopCommand()
