SampleTransport

agents:
    humans: Nurse
    robots: Robot

locations:
    PatientFloor,
    Laboratory

resources:
    Samples

// The following sections are likely descriptions of the pattern's logic
// or actions, rather than direct LIRAs executable code blocks in this context.
// Commenting them out to resolve parsing errors related to their structure
// and placement at the top level.

// Conditions:

// - If the nurse is at the patient floor and there is a sample to be collected, then:

// moveTo PatientFloor

// Wait for 5 minutes

// - If the robot is at the laboratory and there is a locked drawer available, then:

// moveTo Laboratory

// openLockedDrawer

// - If the nurse has inserted data about the sample in the track system, then:

// insertDataInTrackSystem

// - If the time between sample collection and laboratory delivery is longer than 30 minutes, then:

// waitFor30Minutes

// Actions:

// - Move to patient floor
// moveTo PatientFloor

// - Collect sample using barcode scanning
// scanBarcode

// - Move to laboratory
// moveTo Laboratory

// - Open locked drawer
// openLockedDrawer

// - Pick up sample using robotic arm or laboratory personnel
// pickUpSample

// - Sort samples
// sortSamples

// - Load samples into entry-module of analysis machines
// loadSamples

// - Log information about where and when a given sample was picked securely
// logSamplePickupInformation

// - Track time between sample collection and laboratory delivery
// trackSampleDeliveryTime

// Sequences:

// sequence:
// 1: moveTo PatientFloor
// 2: waitFor5Minutes
// 3: insertDataInTrackSystem
// 4: pickUpSample
// 5: logSamplePickupInformation
// 6: trackSampleDeliveryTime

// - If the robot is at the laboratory and there is a locked drawer available, then:

// sequence:
// 1: moveTo Laboratory
// 2: openLockedDrawer
// 3: pickUpSample
// 4: sortSamples
// 5: loadSamples
// 6: trackSampleDeliveryTime

// Continuations:

// continuation: 3-5

// Sub-Sequences:

// subSequence:
// 1: waitFor5Minutes	
// 2: insertDataInTrackSystem
// 3: pickUpSample
// 4: logSamplePickupInformation
// 5: trackSampleDeliveryTime

// subSequence:
// 1: openLockedDrawer
// 2: pickUpSample
// 3: sortSamples
// 4: loadSamples
// 5: trackSampleDeliveryTime

// Synchronization:

// synchronize: 1-3, 5-6

// Conditional Statements:

// if/else:
// If the time between sample collection and laboratory delivery is longer than 30 minutes then:
// 1: waitFor30Minutes

// elseIf the nurse has inserted data about the sample in the track system then:
// 1: insertDataInTrackSystem

// elseIf the robot is at the laboratory and there is a locked drawer available then:
// 1: moveTo Laboratory

// else:
// 1: waitFor5Minutes

// Binary Operators:

// not: !
// and: &&
// or: ||

// Thresholds:

// >: greater than
// <: less than
// =: equal to
