SampleTransportation

agents:
	humans: Nurse, LaboratoryPersonnel
	robots: RobotArm
locations: patientFloor, laboratory
resources: sample, entryModule

Nurse:
	1-3: fetch sample
	4: pick sample
	5: deliver sample

LaboratoryPersonnel:
	1-2: moveTo laboratory
	3: moveTo secureDrawers
	4-5: pick sample
	6: deposit entryModule

RobotArm:
	1: patrol(patientFloor, laboratory) until !need(sample) && !isUnlocked()
	2-3: moveTo patientFloor
	4: moveTo secureDrawers
	5: pickSample(sample)
	6: scanBarcode(sample)
	7-8: moveTo laboratory
	9: sortSamples()
	10: loadSamples(entryModule)

RobotArm:

unlockSecureDrawers():
	1: moveTo secureDrawers()
	2: unlock()

isUnlocked():
	1: moveTo laboratory
	2: return !secureDrawers().locked()

pickSample(sample):
	1: moveTo sample
	2: pick()

scanBarcode(sample):
	1: moveTo barcode()
	2: scan()

sortSamples():
	1-3: moveTo sortLocation()
	4-6: sort()

loadSamples(entryModule):
	1-3: moveTo entryModule()
	4-6: load()

secureDrawers():
	1-2: moveTo secureLocation()
	3: return location.locked()

track(sample):
	1: moveTo trackLocation()
	2: log()
