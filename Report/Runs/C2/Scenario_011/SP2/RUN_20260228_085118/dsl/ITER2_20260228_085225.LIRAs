SampleDeliveryScenario

agent 1: moveTo Lab
agent 2: deliveryToLab
sequence 1:
  sub-sequence 1:
    actions:
      - moveTo PatientFloor
      - collectSample
    conditions:
      - barcodePresent sample
  sub-sequence 2:
    actions:
      - insertDataInTrackSystem sample
    conditions:
      - sampleReadyForCollection
  sub-sequence 3:
    actions:
      - secureLockedDrawerOpen sample
    conditions:
      - authorizedPersonnelOrRobotInLocation Lab
    continuation: deliveryToLab
sequence 2:
  sub-sequence 1:
    actions:
      - pickSampleFromDrawers
    conditions:
      - barcodePresent sample
    synchronizations:
      - labPersonnelPickupSample
  sub-sequence 2:
    actions:
      - analyzeSample
    conditions:
      - sampleReadyForAnalysis
    continuation: saveAnalysisResults
