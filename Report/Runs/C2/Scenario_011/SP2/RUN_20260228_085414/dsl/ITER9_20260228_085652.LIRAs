Medical_Sample_Processing

agents:
	humans: Nurse1
	robots: Robot1
locations: patientFloors, laboratory, analysisMachine
resources: samples, lockedDrawers

Nurse1:
	1-4: moveTo patientFloors
	5: moveTo laboratory
	6: insertData samples
	7: collectSample
	8: moveTo lockedDrawers
	9: openLockedDrawers
	10: pick samples
	11: scanBarcode sample
	12: deliver samples analysisMachine
	13: logInformation
	14: trackTime
Robot1:
	1-4: moveTo laboratory
	5: receiveDelivery
	6: openLockedDrawers
	7: pick samples
	8: scanBarcode sample
	9: deliver samples analysisMachine
	10: logInformation
	11: trackTime
lockedDrawers:
	1-4: moveTo laboratory
	5: secureLockedDrawers
patientFloors:
	1-4: moveTo laboratory
	5: securePatientFloors
analysisMachine:
	1-4: moveTo laboratory
	5: receiveSamplese
laboratory:
	1-4: moveTo patientFloors
	5: secureLaboratory
