HotelButlerDelivery
agents:
  robots:
    hotel_butler:
  humans:
    guests:
locations:
  starting_point:
  guest_location:
  lifts:
resources:
  storage_box:
  item:
sequences:
  hotel_butler:
    1: moveTo guest_location
    2: open storage_box
    3: request pin_code
    4: deliver item
    5: close storage_box
    6: wait 5 then goto 2
conclusion:
  stop
