Chemo_Bot
agents:
  - robots: Robot
  - humans: Child, Nurse
locations:
  TherapyArea
resources:

Robot:
  1-2: MoveTo(TherapyArea)
      Continuation: IfSoC(Robot), Then ExecuteAction(TellStory());
      Else ExecuteAction(AskQuestion());
      EndIf;
  3-5: EngageWithChild(child)
      Continuation: IfSoC(Child), Then ExecuteAction(InteractVoice());
      Else ExecuteAction(CoordinateBookDelivery());
      EndIf;
  6-8: Pause()
      Continuation: IfSoC(Nurse), Then ExecuteAction(SendCommands());
      Else ExecuteAction(RobotFree());
      EndIf;
