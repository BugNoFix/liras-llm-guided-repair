ChemotherapyRobot

agents:
	humans: Child, Parent
	robots: Robot
locations: chemoTherapyArea
resources: books

Child:
	1-5: moveTo ChemoTherapyArea
	6-7: stop
	8-9: stop

Parent:
	1-4: moveTo ChemoTherapyArea
	5-6: stop
	7-8: deliver books

Robot:
	1-3: moveTo chemoTherapyArea
	4: moveTo Parent
	5: deliver books
	6-9: stop

Nurse:
	1-5: stop
	6-7: stop
	8-9: sendStop()
