Supermarket

agents:
	humans: Parent
	robots: Robot
locations: l1, l2, l3, l4
resources: water, books

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4
	5: stop
	6: deliver books

Parent:
	1-4: moveTo l4
	5: stop

Robot:
	1-3: moveTo l1
	2-3: stop
	4: deliver books

Child:
	1-3: stop
	4: narrate(story)

Nurse:
	1-4: moveTo l4
	5: coordinate(start, pause, stop)

Robot:
	1-3: moveTo l1
	   askSimpleQuestion(parent)
	2-3: engage(parent, books)
	4: deliverBooks(books)

Parent:
	1-4: moveTo l4
	5: coordinate(start, pause, stop)
