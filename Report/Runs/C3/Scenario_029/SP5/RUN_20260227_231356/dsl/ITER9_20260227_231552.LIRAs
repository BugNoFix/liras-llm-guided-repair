RobotTherapySession:
agents:
  robots:
    Robot: description ""
    AutonomousCart: description ""
  humans:
    Nurse: description ""
sequences:
conclusion:
  success:
    expression: Robot.hasToldStory() && Nurse.hasPausedSession()
  failure:
    expression: Robot.hasNotToldStory() || Nurse.hasNotPausedSession()
