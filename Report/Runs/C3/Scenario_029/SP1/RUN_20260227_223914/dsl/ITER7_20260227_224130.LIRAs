Chemotherapy_Therapy
agents:
  robot A1
  robot A2
  robot An
locations:
  L1:
  L2:
  Lm:
resources:
  R1:
  R2:
  Rn:

// Define the sequence
sequence {
  // Start condition
  if (SoC(A1)) {
    // Action 1: Move to location L1
    moveTo(L1)
    // Ask a simple question to let children shape the narrative
    ask(A1, "What is your favorite animal?")
    // Wait for a response
    wait(A1, "response")
  }
  
  // Sub-sequence 1: Engage with children in the therapy area
  subSequence {
    // Move to location L2
    moveTo(L2)
    // Ask follow-up questions based on child's response
    ask(A1, "Why do you like that animal?")
    // Wait for a response
    wait(A1, "response")
  } until (weight(R1) > 0.5)
  
  // Sub-sequence 2: Deliver books via autonomous cart
  subSequence {
    // Move to location L3
    moveTo(L3)
    // Coordinate with the robot to deliver books
    coordinated(A2, "deliverBooks", R2)
    // Wait for book delivery to complete
    wait(A2, "bookDelivery")
  } until (weight(R2) > 0.5)
  
  // Pause if nurses request it
  if (pause(A1)) {
    // Wait for the pause to end
    wait(A1, "pauseEnd")
  }
}

// Define the conclusion conditions
conclusion {
  // All sub-sequences have completed
  all(subSequence)
  
  // Weight of resources has reached a threshold
  weight(R1) > 0.8
}
