AMR_photovoltaic_pipeline
agents:
	humans: Nurse, Doctor
	robots: ServiceBot
locations: room7002, elevator, room3201
resources: basket, objectToBeTransported

Nurse:
	1: moveTo ServiceBot

Doctor:

ServiceBot:
	1-5: moveTo room7002 until not isAt(elevator)
	6: moveTo whoNeed(basket)
	7: askForHumanAssistanceToKnowWhenCorrectFloorIsReached()
	8: moveTo elevator
	9-10: askForHumanAssistanceToKnowWhenServiceGoalIsReached()
	11: moveTo serviceGoalLocation()

// Define task 1: navigate from current location to service start location
task 1:
	moveTo room7002

// Define task 2: wait for human to put the object to be transported in basket, and get confirmation
task 2:
	askForHumanConfirmation(basket)

// Define task 3: navigate from room 7002 to the 7th floor elevator
task 3:
	moveTo elevator

// Define task 4: ask for human assistance to take the elevator to the 3rd floor
task 4:
	askForHumanAssistanceToTakeElevator()

// Define task 5: navigate inside the elevator
task 5:
	moveInsideElevator()

// Define task 6: ask for human assistance to know when correct floor is reached
task 6:
	askForHumanAssistanceToKnowWhenCorrectFloorIsReached()

// Define task 7: navigate out of the elevator
task 7:
	moveOutsideElevator()

// Define task 8: navigate from the 3rd floor elevator to service goal location
task 8:
	moveTo serviceGoalLocation()

// Define task 9: wait for human to collect object and get service completion confirmation
task 9:
	askForHumanConfirmation(serviceGoalLocation())

// Define task 10: move to the next goal location (room 3201)
task 10:
	moveToNextGoalLocation()
