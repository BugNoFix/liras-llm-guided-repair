Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4, room_7002, seventh_floor_elevator, third_floor_elevator, room_3201
resources: none

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4
	5: skip if !humans
	   colaborativeGrasping()

Human:
	1-4: moveTo l4
	5:  colaborativeGrasping()

Task 1:
	moveTo room_7002
	waitForConfirmation()

Task 2:
	moveTo room_7002
	waitForObject()
	getConfirmation()

Task 3:
	moveTo seventh_floor_elevator
	askForHumanAssistance()

Task 4:
	moveTo third_floor_elevator
	askForHumanAssistance()

Task 5:
	moveTo third_floor_elevator
	waitForCorrectFloor()

Task 6:
	moveTo seventh_floor_elevator
	askForHumanAssistance()

Task 7:
	moveTo l4
	waitForObject()

Task 8:
	moveTo room_3201
	waitForServiceCompletion()
