Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4, Loc7002, Loc7thFloorElevator, Loc3rdFloor, LocRoom3201
resources: none

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	   checkItems
	4: moveTo l4
	   checkItems
	5: skip if !presence(humans)
	6: moveTo Loc7002
	   waitForHuman()
	7: moveTo Loc7thFloorElevator
	   askForHumanAssistance()
	8: moveTo Loc3rdFloor
	   askForHumanAssistance()
	9: moveTo goalLocation
	   waitForHuman()
	10: finishService()

Human:
	1-4: moveTo l4
	5:  colaborativeGrasping(none)
