MedicalSampleProcessing:
  agents:
    robots:
      Robot1
      Robot2
  locations:
    Lab
    PatientFloor
  resources:
    sample
  sequences:
    Robot1:
      1: moveTo Lab
      2: moveTo PatientFloor
      3: pick sample if BarcodePresent(sample)
      4: wait until SampleReadyForCollection
      5: wait until AuthorizedPersonnelOrRobotInLocation(Lab)
    Robot2:
      1: pick sample if BarcodePresent(sample)
      2: wait until LabPersonnelPickupSample
      3: wait until SampleReadyForAnalysis
      4: deliver sample to Lab
