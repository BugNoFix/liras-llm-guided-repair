SampleTransport
agents: Nurse: human, Robot: robot
locations: PatientFloor, Laboratory
resources: Samples

sequence:
  1. moveTo PatientFloor
  2. waitFor5Minutes
  3. insertDataInTrackSystem
  4. pickUpSample
  5. logSamplePickupInformation
  6. trackSampleDeliveryTime

sequence:
  1. moveTo Laboratory
  2. openLockedDrawer
  3. pickUpSample
  4. sortSamples
  5. loadSamples
  6. trackSampleDeliveryTime

continuation: 3-5

subSequence:
  1. waitFor5Minutes	
  2. insertDataInTrackSystem
  3. pickUpSample
  4. logSamplePickupInformation
  5. trackSampleDeliveryTime

subSequence:
  1. openLockedDrawer
  2. pickUpSample
  3. sortSamples
  4. loadSamples
  5. trackSampleDeliveryTime

synchronize: 1-3, 5-6

if/else:
  If the time between sample collection and laboratory delivery is longer than 30 minutes then:
    1. waitFor30Minutes

  elseIf the nurse has inserted data about the sample in the track system then:
    1. insertDataInTrackSystem

  elseIf the robot is at the laboratory and there is a locked drawer available then:
    1. moveTo Laboratory

  else:
    1. waitFor5Minutes

not: !
and: &&
or: ||

>: greater than
<: less than
=: equal to
