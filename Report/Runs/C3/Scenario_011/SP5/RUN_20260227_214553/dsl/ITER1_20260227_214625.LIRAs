Transport Samples to Laboratory
agents:
  robots:
    Agent1
    Agent2
locations:
  locked_drawer
  laboratory
  entry_module
resources:
  sample

Agent1:
  1: moveTo laboratory
  2: deliver sample to laboratory

Agent2:
  1: moveTo locked_drawer
  2: pick sample from locked_drawer
  3: moveTo entry_module
  4: deposit sample to entry_module
