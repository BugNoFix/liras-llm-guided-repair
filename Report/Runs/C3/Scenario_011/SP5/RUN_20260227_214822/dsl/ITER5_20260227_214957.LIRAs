Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4
resources: water

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4
	5: pick water

Human:
	1-4: moveTo l4
	5:  pick water

Laboratory

agents:
	nurses: Nurse
	robots: Robot
locations: lab, patientFloors
resources: samples

Nurse:
	1-4: moveTo patientFloors
	5: fetch samples
	6: enterDataInTrackSystem()
	7: moveTo lab
	8: deliveryRequest(samples)

Robot:
	1: moveTo lab
	2: pickUpSamples()
	3: scanBarcode()
	4: sortSamples()
	5: loadSamplesIntoModule()
	6: securelyLogDeliveryInformation()
	7: trackTimeBetweenSampleCollectionAndDelivery()
