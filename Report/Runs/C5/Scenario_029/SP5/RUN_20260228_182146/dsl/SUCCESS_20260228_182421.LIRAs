Supermarket

agents:
	humans: Parent, Child, Nurse
	robots: Robot
locations: l1, l2, l3, l4
resources: water, books

Robot:
	1: moveTo l1
	2: pick books
	3: moveTo l2
	4: pick books
	5: moveTo l3
	6: pick books
	7: moveTo l4
	8: pick books
	9: deliver books
	10: stop

Parent:
	1-4: moveTo l4
	5: stop

Child:
	1-3: pick books
	4: stop

Nurse:
	1-4: moveTo l4
	5: stop
