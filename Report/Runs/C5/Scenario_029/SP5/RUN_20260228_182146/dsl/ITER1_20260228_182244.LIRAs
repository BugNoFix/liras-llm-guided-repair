Supermarket

agents:
	humans: Parent, Child, Nurse
	robots: Robot
locations: l1, l2, l3, l4
resources: water, books

Robot:
	1: moveTo l1
	   pick books
	2: moveTo l2
	   pick books
	3: moveTo l3
	   pick books
	4: moveTo l4
	   pick books
	5: stop
	   deliver books
	6: deliver books

Parent:
	1-4: moveTo l4
	5: stop

Robot:
	1-3: moveTo l1
	   stop
	2-3: deliver books
	4: deliver books

Child:
	1-3: pick books
	4: stop

Nurse:
	1-4: moveTo l4
	5: stop

Robot:
	1-3: moveTo l1
	   stop
	2-3: deliver books
	4: deliver books

Parent:
	1-4: moveTo l4
	5: stop
