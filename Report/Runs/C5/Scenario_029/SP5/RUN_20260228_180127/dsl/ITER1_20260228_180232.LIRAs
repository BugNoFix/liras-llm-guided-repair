Robot Therapy Session
<pattern name="Robot Therapy Session">
  <inputs>
    <agent1 id="Robot">
      <l1>Tell a story</l1>
      <parameter>Child's name</parameter>
    </agent1>
    <agent2 id="Nurse">
      <l1>Pause session</l1>
    </agent2>
  </inputs>
  <success>
    <condition>
      <expression>Robot.hasToldStory() && Nurse.hasPausedSession()</expression>
    </condition>
  </success>
  <failure>
    <condition>
      <expression>Robot.hasNotToldStory() || Nurse.hasNotPausedSession()</expression>
    </condition>
  </failure>
  <action1 id="TellStory">
    <action body="Robot.tellStory(child.name)">
      Tell a story to the child
    </action>
  </action1>
  <action2 id="PauseSession">
    <action body="Nurse.pauseSession()">
      Pause the session
    </action>
  </action2>
  <action3 id="CoordinateBookDelivery">
    <action body="AutonomousCart.deliverBooks()">
      Coordinate book delivery
    </action>
  </action3>
</pattern>
