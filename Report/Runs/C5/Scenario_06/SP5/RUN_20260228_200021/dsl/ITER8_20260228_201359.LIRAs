HotelRobotButler

agents:
	guest: Guest
	robot: Robot
locations: lobby, rooms
resources: items

Guest:
	1: moveTo lobby
	2: stop
	3: moveTo rooms
	4: stop
	5: pick items
	6: stop

Robot:
	1: moveTo lobby
	2: moveTo rooms
	3: follow guest
	4: deliver items
	5: deliver items
	6: stop
	7: moveTo lobby
