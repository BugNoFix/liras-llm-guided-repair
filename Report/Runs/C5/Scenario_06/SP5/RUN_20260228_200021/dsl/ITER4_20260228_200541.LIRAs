HotelRobotButler

agents:
	Guest: lobby
	HotelRobotButler: lobby
locations:
	lobby: rooms
	rooms: lobby
resources:
	items: lobby

Guest:
	1-4: moveTo lobby
	5: fetch items
	6: moveTo rooms
	7: pick items
	8: pick items
	9: stop

HotelRobotButler:
	1: moveTo lobby
	2: moveTo rooms
	3: moveTo rooms
	4: follow Guest
	5: deliver items
	6: deliver items
	7: stop
	8: moveTo lobby
