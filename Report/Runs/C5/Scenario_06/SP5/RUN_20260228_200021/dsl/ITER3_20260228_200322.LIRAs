HotelRobotButler

agents:
	Guest: 1
	HotelRobotButler: 1
locations: lobby, rooms
resources: items

Guest:
	1-4: moveTo lobby
	5: fetch items
	6: moveTo rooms
	7: fetch items
	8: pick items
	9: deposit items

HotelRobotButler:
	1: moveTo lobby
	2: moveTo rooms
	3: moveTo rooms
	4: follow Guest
	5: deliver items
	6: deliver items
	7: deposit items
	8: moveTo lobby
