pattern Delivery : {
    name : "Delivery Pattern";
    nodes : {
        start : {
            actions : { moveTo guest_location; };
            then : prepare;
        }
        prepare : {
            actions : { pick item; receiveFrom guests; };
            then : serve;
        }
        serve : {
            actions : { deliver item; deposit; };
            then : finish;
        }
        finish : {
            actions : { stop; };
        }
    }
}
