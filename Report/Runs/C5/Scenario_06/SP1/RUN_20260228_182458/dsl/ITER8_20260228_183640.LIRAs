DeliveryPattern

agents : {
    hotel_butler : {
        name : "Hotel Butler"
        location : starting_point
        resources : storage_box
        agents : guests
    }
    guests : {
        name : "Guest"
        location : guest_location
        resources : item
    }
}

environment : {
    location : starting_point, lifts
}

pattern : {
    name : "Delivery Pattern"
    nodes : {
        start : {
            actions : { moveTo guest_location }
            then : prepare
        }
        prepare : {
            actions : { pick storage_box; receiveFrom guests }
            then : serve
        }
        serve : {
            actions : { deliver item; deposit }
            then : finish
        }
        finish : {
            actions : { stop }
        }
    }
}
