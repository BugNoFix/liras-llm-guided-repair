Lobby

agents:
	hotelRobot: lobby
locations: lobby
resources: none

Room

agents:
	guest: room
locations: room
resources: none

butler:
	1-5: moveTo lobby
	6: fetch items
	7: moveTo room
	8: follow guest
	9: fetch storageBox
	10: deliver items

