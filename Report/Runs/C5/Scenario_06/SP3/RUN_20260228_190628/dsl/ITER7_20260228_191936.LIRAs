Hotel

locations: lobby, room, deliveryLocation
resources: storageBox, items

agents:
	hotelRobot:
		1-5: moveTo lobby
		6: fetch items
		7: moveTo room
		8: follow guest
		9: fetch storageBox
		10: deliver items
	guest:
		1: moveTo room
	butler:
		1-5: moveTo lobby
		6: fetch items
		7: moveTo room
		8: follow guest
		9: fetch storageBox
		10: deliver items
	lift:
		1-3: moveTo lobby
		4: moveTo room
	items:
		1-10: deposit storageBox
		11: moveTo deliveryLocation
	presence:
		1-5: moveTo lobby
		6: follow guest
	access:
		1-5: moveTo storageBox
		6: fetch storageBox
	delivery:
		1-3: moveTo deliveryLocation
		4: deliver items

Lobby

locations: lobby
agents: hotelRobot
resources: none

Room

locations: room
agents: guest
resources: none
