LabSampleTransportation

agents:
	humans: Nurse, LaboratoryPersonnel
	robots: RobotArm
locations: patientFloor, laboratory
resources: sample, lockedDrawer

Nurse:
	1-3: moveTo patientFloor
	4: fetch lockedDrawer
	5: deposit lockedDrawer

LaboratoryPersonnel:
	1-2: moveTo laboratory
	3: fetch lockedDrawer
	4-5: pick sample
	6: fetch sample
	7-8: deposit sample
	9: deposit sample

RobotArm:
	1-3: moveTo patientFloor
	4-5: pick sample
	6: fetch sample
	7-8: deposit sample
	9: deposit sample

Laboratory:
	1-2: moveTo laboratory
	3-4: fetch lockedDrawer
	5-6: fetch lockedDrawer
	7-8: deposit lockedDrawer
