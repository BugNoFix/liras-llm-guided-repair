Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4
resources: water

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4
	5: pick water

Human:
	1-4: moveTo l4
	5: pick water

Laboratory

agents:
	nurses: Nurse
	robots: Robot
locations: lab, patientFloors
resources: samples

Nurse:
	1-4: moveTo patientFloors
	5: pick samples
	6: stop
	7: moveTo lab
	8: deliver samples

Robot:
	1: moveTo lab
	2: pick samples
	3: stop
	4: stop
	5: deposit samples
	6: stop
	7: stop
