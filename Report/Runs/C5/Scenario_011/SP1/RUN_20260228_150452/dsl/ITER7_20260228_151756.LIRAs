LabSampleTransportation

locations: patientFloors, laboratory, sampleLocation
resources: samples

agents:
	nurses
	robots

nurses:
	1-5: moveTo patientFloors
	6: moveTo laboratory
	7: stop
	8: moveTo sampleLocation
	9: pick samples
	10: stop
	11: moveTo laboratory
	12: stop
	13: pick samples
	14: stop

robots:
	1-4: moveTo laboratory
	5: receiveFrom nurses
	6: pick samples
	7: deposit samples
	8: deposit samples
	9: stop

scenario:
	1-3: nurses move to patient floors and collect samples
	4-6: nurses enter data into track system and move to sample location
	7-9: robots move to laboratory and receive delivery of samples
	10-12: nurses collect samples and scan barcodes
	13-15: robots sort and load samples into analysis machines
	16-18: nurses close locked drawers and track time
