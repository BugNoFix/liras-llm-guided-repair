LabSampleTransportation

agents:
	nurses: Nurse
	robots: Robot

locations: patientFloors, laboratory
resources: samples

nurses:
	1-5: moveTo patientFloors
	6: receiveFrom robots
	7: stop
	8: moveTo patientFloors
	9: pick samples
	10: stop
	11: moveTo laboratory
	12: stop
	13: pick samples
	14: stop

robots:
	1-4: moveTo laboratory
	5: receiveFrom nurses
	6: stop
	7: stop
	8: deposit samples
	9: stop
