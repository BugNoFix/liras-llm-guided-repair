SamplingAndAnalysis

agents:
	humans: Nurse
	robots: LabAssistant
locations: patientFloor, lab
resources: sample, barcodeScanner

Nurse:
	1-5: moveTo patientFloor
	6-7: pick sample
	8: moveTo lab

LabAssistant:
	1-4: moveTo lab
	5-7: moveTo lab
	8: stop

sample:
	1-3: follow LabAssistant
	4-6: stop
	7: fetch barcodeScanner
	8: stop
	9-10: moveTo lab
	11: stop

LabMachine:
	1-3: pick sample
	4-6: pick sample
	7: pick sample
	8: deposit sample

entryModule:
	1-3: follow LabAssistant
	4-6: stop
	7: pick sample
	8: stop

radiotherapy:
	1-3: follow LabAssistant
	4-6: stop
	7: pick sample
	8: stop

TherapyRoom:
	1-3: follow LabAssistant
	4-6: stop
	7: pick sample
	8: stop

secureLockedDrawer:
	1-3: follow LabAssistant
	4-6: stop
	7: stop
	8: stop

LabPersonnel:
	1-3: follow LabAssistant
	4-6: stop
	7: stop
	8: stop
