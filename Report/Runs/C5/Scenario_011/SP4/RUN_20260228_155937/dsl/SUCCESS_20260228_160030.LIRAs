NurseAssistant

agents:
	humans: Nurse
	robots: LabAssistant, LabRobot, LabAnalysisMachine
locations: patientFloor, labRoom
resources: barcodeScanner, lockedDrawers, sample, trackSystem

Nurse:
	1: pick lockedDrawers
	2-5: receiveFrom LabAssistant
	6: deposit trackSystem

LabAssistant:
	1: moveTo patientFloor
	2-4: stop
	5: pick sample
	6-7: deposit sample
	8: moveTo Nurse

LabRobot:
	1-4: moveTo labRoom
	5: pick lockedDrawers
	6: moveTo Nurse

LabAnalysisMachine:
	1-4: pick sample
	5: deposit sample
