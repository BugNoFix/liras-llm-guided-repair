Lab_Sample_Transportation

agents:
	humans: Nurse
	robots: Robot
locations: patientFloors, laboratory
resources: samples

Nurse:
	1-5: moveTo patientFloors
	6: requestDelivery(laboratory)
	7: enterData(samples)
	8: moveTo sampleLocation
	9: collectSample()
	10: scanBarcode(sample)
	11: moveTo lockedDrawer()
	12: openLockedDrawer()
	13: pickSample()
	14: closeLockedDrawer()

Robot:
	1-4: moveTo laboratory
	5: receiveDelivery()
	6: scanBarcode(sample)
	7: sortSamples()
	8: loadModule()
	9: trackTime()
