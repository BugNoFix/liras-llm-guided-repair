NurseAssistant

agents:
	humans: Nurse
	robots: LabAssistant
locations: patientFloor, labRoom
resources: barcodeScanner, lockedDrawers

Nurse:
	1: pick lockedDrawers
	2-5: receiveFrom LabAssistant until !lockedDrawers
	6: insertData(trackSystem)

LabAssistant:
	1: patrol(patientFloor, labRoom) until isRequested(LabAssistant)
	2-4: stop
	5: pick(sample) scan(barcodeSample) sort(samples) load(samples, LabAssistant)
	6-7: collaborativeUnload(LabAssistant) until weight(LabAssistantLoad) < th
	8: moveTo Nurse

LabRobot:
	1-4: patrol(labRoom) until authorizedPersonnelOrRobots(lockedDrawers)
	5: openLockedDrawers(sample) pickUp(sample) scan(barcodeSample) log(time, sample)
	6: moveTo Nurse

LabAnalysisMachine:
	1-4: acceptSampling(sample) until authorizedPersonnelOrRobots(lockedDrawers)
	5: sortAndLoad(samples) log(time, sampling)

authorizedPersonnelOrRobots:
	LabAssistant
	LabRobot
location: lockedDrawers

weight: th

barcodeScanner:
	1-2: scanBarcode(sample)

lockedDrawers:
	1-3: open(lockedDrawer) pickUp(sample) close(lockedDrawer)

time: t

sampling: s
