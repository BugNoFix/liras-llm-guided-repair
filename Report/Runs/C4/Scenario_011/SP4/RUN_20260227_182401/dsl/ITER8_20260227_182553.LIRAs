Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4
resources: water

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4
	5: stop
	6: sortSample()
	7: loadSampleIntoAnalysisMachine()
	8: logSampleDeliveryInfo()
	9: waitTimeBetweenCollectionAndDelivery()

Human:
	1-4: moveTo l4
	5: requestDeliveryToLaboratory()

Laboratory

agents:
	robots: Robot
locations: labLocation
resources: laboratoryEquipment

Robot:
	1: moveTo labLocation
	2: pickSampleFromSecureLockedDrawer()
	3: scanBarcode(sample)
	4: sortSample()
	5: loadSampleIntoAnalysisMachine()
	6: logSampleDeliveryInfo()
	7: securelyOpenLockedDrawer()

LabSample:
	name: ID
	location: labLocation
	barcode: ID
