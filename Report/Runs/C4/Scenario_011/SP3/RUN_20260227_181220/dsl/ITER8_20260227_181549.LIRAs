AMR_photovoltaic_pipeline

agents:
robots: Robot1, Robot2, Robot3, Robot4

locations:
    warehouse,
    surface_texturization_start,
    surface_texturization_end

resources:
    raw_materials,
    texturized_materials

Robot1:
    1: moveTo warehouse
    2: fetch raw_materials
    3: moveTo surface_texturization_start
    4: deliver raw_materials
    5: moveTo surface_texturization_end
    6: fetch texturized_materials
