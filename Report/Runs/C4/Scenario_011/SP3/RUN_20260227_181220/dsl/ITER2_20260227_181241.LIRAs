AMR_photovoltaic_pipeline

agents:
    robots: Robot1, Robot2, Robot3, Robot4

locations:
    warehouse,
    surface_texturization_start,
    surface_texturization_end

resources:
    raw_materials,
    texturized_materials

Robot1:
    1: moveTo warehouse
    pick raw_materials
    moveTo surface_texturization_start
    drop raw_materials
    2: moveTo surface_texturization_end
    pick texturized_materials
    3:
    4:
