SamplingAndAnalysis

agents:
	humans: Nurse
	robots: LabAssistant
locations: patientFloor, lab
resources: sample, barcodeScanner

Nurse:
	1-5: collectSample(patientFloor)
	6-7: enterData(sample)
	8: requestDelivery(lab)

LabAssistant:
	1-4: patrol(lab) until !isReadyForDelivery(sample)
	5-7: deliverSample(lab)
	8: logInformation(sample, lab)

sample:
	1-3: moveTo LabAssistant
	4-6: stop
	7: scanBarcode(barcodeScanner)
	8: sort()
	9-10: moveTo entryModule(analysisMachine)
	11: deliver()

LabMachine:
	1-3: acceptDelivery(sample)
	4-6: prepareForAnalysis(sample)
	7: startAnalysis(sample)
	8: finishAnalysis(sample)

entryModule:
	1-3: moveTo LabAssistant
	4-6: stop
	7: acceptDelivery(sample)
	8: logInformation(sample, lab)

radiotherapy:
	1-3: moveTo LabAssistant
	4-6: stop
	7: acceptDelivery(sample)
	8: logInformation(sample, lab)

TherapyRoom:
	1-3: moveTo LabAssistant
	4-6: stop
	7: acceptDelivery(sample)
	8: logInformation(sample, lab)

secureLockedDrawer:
	1-3: moveTo LabAssistant
	4-6: stop
	7: open()
	8: close()

LabPersonnel:
	1-3: moveTo LabAssistant
	4-6: stop
	7: open()
	8: close()
