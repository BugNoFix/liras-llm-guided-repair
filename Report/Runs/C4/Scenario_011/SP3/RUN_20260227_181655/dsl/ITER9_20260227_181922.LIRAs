Supermarket

agents:
	humans: Human
	robots: Robot, RoboticArm
locations: l1, l2, l3, l4
resources: water

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4

Human:
	1-4: moveTo l4
	5: pick water

RoboticArm:
	1: moveTo l1
	   checkItems
	2: moveTo l2
	   checkItems
	3: moveTo l3
	   checkItems
	4: moveTo l4
	   checkItems
	5: skip if !presence(humans)
	   colaborativeGrasping(water)

Human:
	1-4: moveTo l4
	5:  colaborativeGrasping(water)
