Transport_Samples_to_Laboratory

agents:
    humans: Nurse
    robots: SampleRobot

locations:
    sample_collection_point,
    locked_drawer,
    lab_entry_module,
    lab_analysis_station

resources:
    sample

Nurse:
    1: moveTo sample_collection_point
    deposit sample to locked_drawer

SampleRobot:
    1: moveTo locked_drawer
    pick sample
    moveTo lab_entry_module
    deposit sample
    moveTo lab_analysis_station
