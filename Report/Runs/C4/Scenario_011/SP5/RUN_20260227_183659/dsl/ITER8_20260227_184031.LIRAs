LabSampleTransportation

agents:
	humans: Nurse, LaboratoryPersonnel
	robots: RobotArm
locations: patientFloor, laboratory
resources: sample, lockedDrawer

Nurse:
	1-3: moveTo patientFloor
	4: pick lockedDrawer until position(RobotArm, patientFloor)
	5: pick lockedDrawer

LaboratoryPersonnel:
	1-2: moveTo laboratory
	3: pick lockedDrawer
	4-5: pick sample until !sample
	6: scanBarcode(sample)
	7-8: sortSampleseparately until sorted()
	9: loadSample(entryModule)

RobotArm:
	1-3: moveTo patientFloor
	4-5: pickSample(lockedDrawer) until !samplePicked()
	6: scanBarcode(sample)
	7-8: sortSampleseparately until sorted()
	9: loadSample(entryModule)

Laboratory:
	1-2: moveTo laboratory
	3-4: logTime(lockedDrawer)
	5-6: trackDelivery(lockedDrawer) until delivery(lockedDrawer)
	7-8: securelyLogData(lockedDrawer)
