SampleTransport

agents:
	humans: Nurse, LaboratoryPersonnel
	robots: RoboticArm
locations: patientFloor, laboratory
resources: sample, lockedDrawer

Nurse:
	1-5: pick sample
	6: deposit lockedDrawer
	7: deliver laboratory

RoboticArm:
	1-4: moveTo patientFloor until !delivery(laboratory)
	5: moveTo lockedDrawer
	6-8: scanBarcode(sample)
	9: sort(sample)
	10: load(sample, entryModule)
	11: skip if barcode(locked drawer) != barcode(sample)
	12: moveTo laboratory
	collaborativeOpenLockedDrawer()

LaboratoryPersonnel:
	1-3: patrol(laboratory) until delivery(laboratory)
	4-6: openLockedDrawer()
	7-9: logInformation()

RoboticArm:
	10: skip if !authorizedPersonnelOrRobot(location)
	11: moveTo locked drawer
	12: collaborativeOpenLockedDrawer()

Laboratory:
	1-3: patrol(laboratory) until delivery(laboratory)
	4-6: logTimeBetweenCollectionAndDelivery()

RoboticArm:
	10: skip if !delivery(laboratory)
	11: moveTo locked drawer
	12: collaborativeOpenLockedDrawer()
