SampleDeliveryProcess

agents:
    robots: Robot1
    humans: LabPersonnel

locations:
    Lab,
    PatientFloor,
    TrackSystem,
    LockedDrawer,
    Drawers,
    AnalysisMachine,
    Storage

resources:
    sample

Robot1:
    1: moveTo Lab
    2: moveTo PatientFloor
    3: pick sample
    4: moveTo TrackSystem
    5: deposit sample
    6: moveTo LockedDrawer
    7: deposit sample

Robot2:
    1: moveTo Drawers
    2: pick sample
    3: deposit sample

LabPersonnel:
    1: moveTo Drawers
    2: pick sample
    3: moveTo AnalysisMachine
    4: wait 1
    5: moveTo Storage
    6: deposit sample
