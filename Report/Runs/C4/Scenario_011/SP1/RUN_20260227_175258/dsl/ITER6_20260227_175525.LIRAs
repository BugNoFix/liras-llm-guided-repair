SampleTransport

agents:
    humans: HumanAgent
    robots: RobotAgent

locations:
    PatientFloor,
    Laboratory

resources:
    Samples

Nurse:
    1: moveTo PatientFloor
    2: waitFor5Minutes
    3: insertDataInTrackSystem
    4: pick Samples
    5: logSamplePickupInformation
    6: trackSampleDeliveryTime

Robot:
    1: moveTo Laboratory
    2: openLockedDrawer
    3: pick Samples
    4: sortSamples
    5: loadSamples
    6: trackSampleDeliveryTime
