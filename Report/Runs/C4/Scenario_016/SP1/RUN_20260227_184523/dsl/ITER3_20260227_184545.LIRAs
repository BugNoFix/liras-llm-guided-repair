Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4, loc7002, elevator7thFloor, thirdFloor
resources: water

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4
	5: skip if !presence(humans)
	6-8: colaborativeGrasping(water)
	9-12: moveTo loc7002
	13-14: waitForHuman()
	15-18: moveTo elevator7thFloor
	19-22: askForHumanAssistance()
	23-26: moveTo thirdFloor
	27-30: askForHumanAssistance()
	31-34: moveOutOfElevator()
	35-38: moveToServiceGoalLocation()

Human:
	1-4: moveTo l4
	5-8: waitForRobotGrasping(water)
	9-12: collectObject()
	13-16: getServiceCompletionConfirmation()
