Drone_Delivery_Service

agents:
    robots: Drone1, Drone2
    humans: Human

locations:
    currentLocation,
    serviceStartLocation,
    elevatorLocation7thFloor,
    elevatorLocation3rdFloor,
    goalLocationRoom3201

resources:
    basket

Drone1:
    1: moveTo currentLocation
    2: waitFor Human
    3: moveTo serviceStartLocation
    4: waitForConfirmation
    5: moveTo elevatorLocation7thFloor
    6: askForHumanAssistance
    7: moveInsideElevator
    8: askForHumanAssistance
    9: moveTo goalLocationRoom3201
    10: waitForHumanCollection

Human:
    1: putObjectInBasket
