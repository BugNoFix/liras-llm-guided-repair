Service_Navigation

agents:
    robots:
        Robot1
        Robot2
        Robot3
        Robot4
        Robot5
        Robot6
        Robot7
        Robot8

locations:
    currentLocation,
    serviceStartLocation,
    elevatorLocation,
    floorLocation,
    serviceGoalLocation

resources:
    object

