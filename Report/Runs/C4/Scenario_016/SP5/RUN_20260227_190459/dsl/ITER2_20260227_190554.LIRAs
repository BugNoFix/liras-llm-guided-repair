    1: moveTo serviceStartLocation

Robot2:
    1: pick object

Robot3:
    1: moveTo elevatorLocation

Robot4:
    1: moveTo floorLocation

Robot5:
    1: moveTo elevatorLocation

Robot6:
    1: moveTo floorLocation

Robot7:
    1: moveTo floorLocation

Robot8:
    1: moveTo serviceGoalLocation
