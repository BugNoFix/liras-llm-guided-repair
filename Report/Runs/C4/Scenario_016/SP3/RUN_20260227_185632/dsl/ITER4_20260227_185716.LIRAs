Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4, room_7002, seventh_floor_elevator, third_floor, room_3201
resources: none

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4
	5: skip if position(Human, l1)
	6: moveTo room_7002
	7: moveTo seventh_floor_elevator
	   askForHumanAssistance()
	8: moveTo third_floor
	   askForHumanAssistance()
	9: moveTo room_3201
	   waitForHuman()
	10: finishService()

Human:
	1-4: moveTo l4
	5:  colaborativeGrasping(none)
