	waitForObject()
	getConfirmation()

Task 3:
	moveTo 7th floor elevator
	askForHumanAssistance()

Task 4:
	moveTo 3rd floor elevator
	askForHumanAssistance()

Task 5:
	moveTo 3rd floor elevator
	waitForCorrectFloor()

Task 6:
	moveTo 7th floor elevator
	askForHumanAssistance()

Task 7:
