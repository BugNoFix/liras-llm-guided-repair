Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4, room7002, seventh_floor_elevator, third_floor_elevator, room3201
resources: none

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4
