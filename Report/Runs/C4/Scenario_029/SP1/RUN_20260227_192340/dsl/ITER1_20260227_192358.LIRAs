ChemotherapyRobot

agents:
	humans: Child, Parent
	robots: Robot
locations: chemoTherapyArea
resources: books

Robot:
	1-5: moveTo chemoTherapyArea until !isStart()
	6-8: engageWithChild(Child)
	9-12: stop
	13-17: deliverBooksViaCart()
	18-20: pause()

Parent:
	1-4: moveTo Child
	5-7: askQuestion(Robot, Child)
	8-10: shapeNarrative(Robot, Child)

Child:
	1-4: listenToStory(Robot)
	5-7: interactWithStory(Robot)
	8-10: influenceNarrative(Robot)

Nurse:
	1-3: sendStartCommand(Robot)
	4-6: sendPauseCommand(Robot)
	7-9: sendStopCommand(Robot)

BooksCart:
	1-2: moveAround(chemoTherapyArea) until !isStart()
	3-5: deliverBooksToChild(Child)
