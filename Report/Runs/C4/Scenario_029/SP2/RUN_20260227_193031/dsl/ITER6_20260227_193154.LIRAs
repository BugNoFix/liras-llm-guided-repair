Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4
resources: water

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4
	5: skip if !position(Human, l1)
	6: askQuestion
	7: listen(response)
	8: continueStory(response)
	9: deliverBooks(books)
	10: coordinateWithNurse()

Human:
	1-4: moveTo l4
	5:  colaborativeGrasping(water)
