Robot_Therapy_Session

agents:
    robots: Robot, AutonomousCart
    humans: Nurse

locations:
    therapy_room,
    child_room,
    delivery_point

resources:
    book

Robot:
    1: moveTo therapy_room
    2: stop
    3: stop
    4: deliver book to AutonomousCart

AutonomousCart:
    1: receiveFrom Robot book
    2: moveTo delivery_point
    3: deposit book

Nurse:
    1: moveTo therapy_room
    2: stop
