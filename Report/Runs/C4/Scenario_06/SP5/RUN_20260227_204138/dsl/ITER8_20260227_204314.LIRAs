HotelRobotButler

agents:
	humans: Guest
	robots: HotelRobotButler
locations: lobby, rooms
resources: items

Guest:
	1-4: moveTo lobby
	6: moveTo room
	8: pick items
	9: closeStorageBox()

Hotel Robot Butler:
	1: moveTo lobby
	2: navigateLifts()
	3: moveTo room
	4: locate(guest)
	5: allowAccess(storageBox, guest)
	6: deliverItem()
	7: closeStorageBox()
	8: returnToLobby()
