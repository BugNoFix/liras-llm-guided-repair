Hotel_Butler

agents:
    robots: robot1

locations: dummy_location
resources: dummy_resource

robot1:
    # Original sub-sequence(deliverItem)(guestRoom) converted to LIRAs steps.
    # Conditional logic (if/else) and custom function calls (storageBox.contains, openStorageBox, wait, closeStorageBox, deliverItem as action) are not LIRAs and are omitted or replaced by simple actions.
    1: moveTo guestRoom
    2: stop # Represents the alternative path if item is not present, or the end of the deliver sequence without further action.

    # Original sub-sequence(navigate)(hotelFloor) converted.
    # Arithmetic (hotelFloor + 1) is not LIRAs.
    3: moveTo hotelFloor

    # Original sub-sequence(operateLift)(lift) converted.
    # Custom function call (executeAction) is not LIRAs.
    4: moveTo lift

    # Original sub-sequence(executeAction)(action) converted.
    # Generic 'executeAction' is not an LIRAs action.
    5: stop
