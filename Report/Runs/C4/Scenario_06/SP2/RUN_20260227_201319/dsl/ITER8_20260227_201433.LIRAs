HotelButler

agents:
	humans: Guest
	robots: Butler
locations: lobby, rooms
resources: item1, item2

Butler:
	1: moveTo lobby until position(Guest, lobby)
	2-4: stop
	5: stop
	6: stop
	7-8: moveTo rooms until position(Guest, rooms)
	9-10: stop
	11: stop

Guest:
	1-4: moveTo roomNumber
	5-7: enterPINCode(roomNumber)
	8-10: receiveItem
