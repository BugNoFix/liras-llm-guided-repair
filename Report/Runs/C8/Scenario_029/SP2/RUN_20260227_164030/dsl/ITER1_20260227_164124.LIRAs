ChemotherapyRobot

agents:
	humans: Child, Parent, Nurse
	robots: Robot

locations: chemoTherapyArea
resources: books

Child:
	1-5: moveTo chemoTherapyArea
	6-7: stop
	8-9: wait

Parent:
	1-4: moveTo chemoTherapyArea
	5-6: stop
	7-8: deposit books

Robot:
	1-3: moveTo chemoTherapyArea
	4: follow Parent
	5: pick books
	6-9: deposit books

Nurse:
	1-5: wait
	6-7: wait
	8-9: wait
