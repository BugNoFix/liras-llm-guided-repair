ChemotherapyRobot

agents:
	humans: Child, Parent, Nurse
	robots: Robot, BooksCart

locations: chemoTherapyArea
resources: books

Robot:
	1-5: moveTo chemoTherapyArea
	6-8: follow Child
	9-12: stop
	13-17: deposit books
	18-20: stop

Parent:
	1-4: follow Child
	5-7: follow Robot
	8-10: follow Robot

Child:
	1-4: follow Robot
	5-7: follow Robot
	8-10: follow Robot

Nurse:
	1-3: follow Robot
	4-6: follow Robot
	7-9: follow Robot

BooksCart:
	1-2: moveTo chemoTherapyArea
	3-5: deposit books
