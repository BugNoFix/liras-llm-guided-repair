Supermarket

agents:
	humans: Human
	robots: Robot

locations: l1, l2, l3, l4
resources: water, books

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4
	5: wait
	6: moveTo l1
	7: pick books
	8: wait
	9: moveTo l3
	10: wait
	11: moveTo l4
	12: deposit books
	13: stop

Human:
	1-4: moveTo l4
	5: stop
