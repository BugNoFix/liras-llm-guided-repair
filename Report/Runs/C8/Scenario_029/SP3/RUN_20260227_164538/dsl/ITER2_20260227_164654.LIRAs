ChemotherapyWard

agents:
	humans: child, parent, nurse
	robots: Robot, Cart

locations: chemotherapyArea
resources: book

Robot:
	1: moveTo chemotherapyArea
	2: follow child
	6: follow parent
	7: pick book
	9: follow nurse

