Supermarket

agents:
	humans: Parent, Child, Nurse
	robots: Robot

locations: l1, l2, l3, l4
resources: water, books

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4
	5: stop
	6: deposit books

Parent:
	1-4: moveTo l4
	5: stop

Child:
	1-3: follow Robot
	4: stop

Nurse:
	1-4: moveTo l4
	5: stop
