SampleTransportation

agents:
	humans: Nurse, LaboratoryPersonnel
	robots: RobotArm

locations: patientFloor, laboratory
resources: sample, entryModule

Nurse:
	1-3: moveTo patientFloor
	4: stop
	5: stop

LaboratoryPersonnel:
	1-2: moveTo laboratory
	3: stop
	4-5: stop
	6: pick entryModule

RobotArm:
	1: moveTo patientFloor
	2-3: moveTo patientFloor
	4: stop
	5: pick sample
	6: stop
	7-8: moveTo laboratory
	9: stop
	10: deposit sample
