Lab_Sample_Transportation

agents:
	humans: Nurse
	robots: Robot

locations: patientFloors, laboratory, sampleLocation, secureLockedDrawer
resources: samples

Nurse:
	1-5: moveTo patientFloors
	6: moveTo laboratory
	8: moveTo sampleLocation
	9: pick samples
	11: moveTo secureLockedDrawer
	13: pick samples

Robot:
	1-4: moveTo laboratory
	5: pick samples
	8: deposit samples
