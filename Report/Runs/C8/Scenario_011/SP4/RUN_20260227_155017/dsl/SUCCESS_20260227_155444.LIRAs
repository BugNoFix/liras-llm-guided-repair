NurseAssistant

agents:
	robots: LabAssistant, LabRobot, LabAnalysisMachine, Nurse

locations: patientFloor, labRoom
resources: barcodeScanner, lockedDrawers

Nurse:
	1: pick lockedDrawers
	2-5: stop
	6: deposit lockedDrawers

LabAssistant:
	1: moveTo patientFloor
	2-4: stop
	5: pick barcodeScanner
	6-7: deposit barcodeScanner
	8: follow Nurse

LabRobot:
	1-4: moveTo labRoom
	5: pick lockedDrawers
	6: follow Nurse

LabAnalysisMachine:
	1-4: pick barcodeScanner
	5: deposit barcodeScanner
