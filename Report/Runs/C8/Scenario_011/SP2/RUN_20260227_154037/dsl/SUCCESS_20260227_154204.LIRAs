Hospital_Scenario

agents:
	humans: Nurse
	robots: Robot

locations: patientFloors, laboratory, lockedDrawers, analysisMachine
resources: samples

Nurse:
	1-4: moveTo patientFloors
	5: stop
	6: stop
	7: pick samples
	8: moveTo lockedDrawers
	9: stop
	10: pick samples
	11: stop
	12: stop
	13: moveTo analysisMachine 
	deposit samples
	14: stop
	15: stop

Robot:
	1-4: moveTo laboratory
	5: stop
	6: stop
	7: pick samples
	8: stop
	9: stop
	10: moveTo analysisMachine 
	deposit samples
	11: stop
	12: stop
