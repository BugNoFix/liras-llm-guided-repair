Hospital_Scenario

agents:
	humans: Nurse
	robots: Robot

locations: patientFloors, laboratory, lockedDrawers, analysisMachine
resources: samples

Nurse:
	1-4: moveTo patientFloors
	5: wait
	6: wait
	7: pick samples
	8: moveTo lockedDrawers
	9: wait
	10: pick samples
	11: wait
	12: wait
	13: moveTo analysisMachine 
	deposit samples
	14: wait
	15: wait

Robot:
	1-4: moveTo laboratory
	5: wait
	6: wait
	7: pick samples
	8: wait
	9: wait
	10: moveTo analysisMachine 
	deposit samples
	11: wait
	12: wait
