SampleTransport

agents:
	humans: Nurse, LaboratoryPersonnel
	robots: RoboticArm

locations: patientFloor, laboratory
resources: sample, lockedDrawer

Nurse:
	1-5: pick sample
	6: deposit lockedDrawer
	7: moveTo laboratory

RoboticArm:
	1-4: moveTo patientFloor
	5: moveTo laboratory
	6-8: pick sample
	9: pick sample
	10: deposit sample
	11: stop
	12: moveTo laboratory
	pick lockedDrawer

LaboratoryPersonnel:
	1-3: moveTo laboratory
	4-6: pick lockedDrawer
	7-9: stop
