	1-2: moveTo laboratory
	3: pick lockedDrawer
	4-5: pick sample
	6: deposit sample
	7-8: deposit sample
	9: deposit sample

RobotArm:
	1-3: moveTo patientFloor
	4-5: pick sample
	6: deposit sample
	7-8: deposit sample
	9: deposit sample
