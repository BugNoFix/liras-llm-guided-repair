HotelButler

agents:
	humans: Guest
	robots: Butler

locations: lobby, rooms
resources: item1, item2

Butler:
	1: moveTo lobby
	2-4: stop
	5: pick item1
	pick item2
	6: moveTo rooms
	7-8: moveTo rooms
	9-10: stop
	11: deposit item1
	deposit item2

Guest:
	1-4: moveTo rooms
	5-7: stop
	8-10: receiveFrom Butler
