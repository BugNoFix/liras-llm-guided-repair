flowchart LR
    SP[("System Prompt")] --> GEN["Generation Component<br>Vertex AI (generation_model)"]
    SC[("User Scenario")] --> GEN
    SH[("J-Shots")] --> GEN
    GEN --> SAVE1["DSL.LIRAs"]
    SAVE1 --> COMP["Local Validation Component<br>java -jar compiler_jar"]
    COMP --> OUT["Compiler output"]
    OUT --> OK{"Valid?"}
    OK -- Yes --> SUCCESS["STOP"]
    OK -- No --> REPAIR["User Prompt"]
    OUT -- compilation output --> REPAIR
    REPAIR --> GEN
    RP[("Repair System Prompt =<br>- Grammar Rules + Instructions<br>- Generative System Prompt<br>- Generative User Scenario")] --> GEN
    SAVE1 -- PREVIOUS DSL --> REPAIR

