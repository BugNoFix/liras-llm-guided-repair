Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4
resources: water

Robot:
	1: moveTo l1
	2: moveTo l2
	3: moveTo l3
	4: moveTo l4
	5: pick water

Human:
	1-4: moveTo l4
	5: pick water

Laboratory

agents:
	humans: Nurse
	robots: Robot
locations: lab, patientFloors
resources: samples

Nurse:
	1-4: moveTo patientFloors
	5: pick samples
	6: moveTo lab
	7: deposit samples

Robot:
	1: moveTo lab
	2: pick samples
	3: deposit samples
