SampleTransport

agents:
	humans: Nurse, LaboratoryPersonnel
	robots: RoboticArm
locations: patientFloor, laboratory
resources: sample, lockedDrawer

Nurse:
	1-5: pick sample
	6: moveTo lockedDrawer
	7: moveTo laboratory

RoboticArm:
	1-4: moveTo patientFloor
	5: moveTo lockedDrawer
	6-8: pick sample
	9: stop
	10: deposit sample
	11: stop
	12: moveTo laboratory

LaboratoryPersonnel:
	1-3: moveTo laboratory
	4-6: pick sample
	7-9: stop
