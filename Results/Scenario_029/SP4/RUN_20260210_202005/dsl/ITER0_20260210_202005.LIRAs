NurseAssistant

agents:
	humans: Child, Parent
	robots: Robot
locations: chemotherapyWard, reservedArea
resources: books

Robot:

1-5: patrol(chemotherapyWard) until start()

Child:
	1-3: interact()
	4: pause()

Parent:
	1-2: collaborativeUnload(bookCart)
	3-4: stop()

Book Cart:
	1-5: autonomousNavigate(chemotherapyWard) until arriveAt(Robot)
	deliverBooks()

Child:
	1-3: shapeNarrative()
	4: pause()

Parent:
	1-2: collaborativeUnload(bookCart)
	3-4: stop()
