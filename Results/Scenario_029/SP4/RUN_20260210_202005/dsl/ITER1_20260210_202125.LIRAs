NurseAssistant

agents:
	humans: Child, Parent
	robots: Robot, BookCart
locations: chemotherapyWard, reservedArea
resources: books

Robot:
	1-5: moveTo chemotherapyWard

Child:
	1-3: stop
	4: stop

Parent:
	1-2: receiveFrom BookCart
	3-4: stop

BookCart:
	1-5: moveTo chemotherapyWard
	6: deliver books

Child:
	1-3: stop
	4: stop

Parent:
	1-2: receiveFrom BookCart
	3-4: stop
