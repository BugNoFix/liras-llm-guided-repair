ChemotherapyRobot

agents:
	humans: Child, Parent, Nurse
	robots: Robot, BooksCart
locations: chemoTherapyArea
resources: books

Robot:
	1-5: moveTo chemoTherapyArea
	6-8: moveTo Child
	9-12: stop
	13-17: deliver books
	18-20: stop

Parent:
	1-4: moveTo Child
	5-7: moveTo Robot
	8-10: stop

Child:
	1-4: stop
	5-7: stop
	8-10: stop

Nurse:
	1-3: moveTo Robot
	4-6: moveTo Robot
	7-9: stop

BooksCart:
	1-2: moveTo chemoTherapyArea
	3-5: deliver books
