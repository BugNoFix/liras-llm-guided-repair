Supermarket

agents:
	humans: Human
	robots: Robot
locations: l1, l2, l3, l4, room 7002, elevator, room 3201
resources: none

Robot:
	1: moveTo l1
	   checkItems
	2: moveTo l2
	   checkItems
	3: moveTo l3
	   checkItems
	4: moveTo l4
	   checkItems
	5: skip if !presence(humans)
	   navigateToServiceStartLocation()
	6-8: waitForHumanAssistance()
	9: serviceGoalReached()

Human:
	1-4: moveTo l4
	5:  navigateToServiceStartLocation()
	6-8: waitForRobotAssistance()
	9: serviceGoalReached()

NavigateToServiceStartLocation:
	1: moveTo room 7002
	2: waitForConfirmation()
	3: navigateToElevator()
	4: askForHumanAssistanceToTakeElevator()
	5: navigateInsideElevator()
	6: askForHumanAssistanceToKnowCorrectFloorReached()
	7: navigateOutOfElevator()
	8: navigateToServiceGoalLocation()

WaitForHumanAssistance:
	1: wait()

NavigateToElevator:
	1: moveTo elevator

AskForHumanAssistanceToTakeElevator:
	1: askForHumanAssistance()

NavigateInsideElevator:
	1: move InsideElevator()

AskForHumanAssistanceToKnowCorrectFloorReached:
	1: askForHumanAssistance()

NavigateOutOfElevator:
	1: moveOutOfElevator()

ServiceGoalReached:
	1: checkIfServiceGoalReached()

MoveToCurrentLocation:
	1: moveTo current location

CheckItems:
	1: check if items are available at the current location

MoveToLocation:
	1: move to the specified location

WaitForConfirmation:
	1: wait for confirmation

askForHumanAssistance:
	1: ask for human assistance

moveToServiceStartLocation:
	1: move to the service start location

moveToElevator:
	1: move to the elevator

moveOutOfElevator:
	1: move out of the elevator

checkIfServiceGoalReached:
	1: check if the service goal has been reached

serviceGoalReachedConfirmation:
	1: check if the service goal has been reached and a confirmation is received.
