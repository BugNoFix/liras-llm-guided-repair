LabDelivery

agents:
	humans: Nurse, LabPersonnel
	robots: Transporter, RoboticArm
locations: PatientFloor, Laboratory, AnalysisMachine
resources: Sample

Nurse:
	1: insertData
	2: deliver Sample

Transporter:
	1: moveTo PatientFloor
	2: receiveFrom Nurse
	   lockDrawer
	3: moveTo Laboratory
	   logSecurely
	4: deliver Sample

RoboticArm:
	1-3: stop
	4: receiveFrom Transporter
	   scanBarcode
	   sort
	5: moveTo AnalysisMachine
	   leave Sample