SampleDelivery

agents:
	humans: Nurse, LabStaff
	robots: DeliveryBot, LabArm
locations: PatientFloor, Lab, AnalysisMachine
resources: Sample

Nurse:
	1: stop
	2: deliver Sample

DeliveryBot:
	1: moveTo PatientFloor
	2: receiveFrom Nurse
	3: moveTo Lab until time(120)
	4: stop

LabArm:
	1-3: stop
	4: skip if !position(DeliveryBot, Lab)
	5: fetch Sample
	6: deliver Sample

LabStaff:
	1-3: stop
	4: skip if !position(DeliveryBot, Lab)
	5: fetch Sample

conclusion:
	success: !possess(DeliveryBot, Sample)
	failure: possess(DeliveryBot, Sample)