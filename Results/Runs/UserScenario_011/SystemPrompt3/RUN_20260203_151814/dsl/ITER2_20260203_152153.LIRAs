LabSampleTransport

agents:
	humans: Nurse, LabPersonnel
	robots: TransportBot, LabArm
locations: PatientFloor, Lab
resources: Sample

Nurse:
	1: stop
	2: stop until position(TransportBot, PatientFloor)
	3: stop

TransportBot default stop:
	1: moveTo PatientFloor
	2: receiveFrom Nurse
	3: moveTo Lab
	4: stop until !possess(TransportBot, Sample)

LabArm:
	1-3: stop until position(TransportBot, Lab) && possess(TransportBot, Sample)
	4: fetch Sample
	5: stop

LabPersonnel:
	1-3: stop until position(TransportBot, Lab) && possess(TransportBot, Sample)
	4: fetch Sample

conclusion:
	success: !possess(TransportBot, Sample)
	failure: time(3600) && possess(TransportBot, Sample)