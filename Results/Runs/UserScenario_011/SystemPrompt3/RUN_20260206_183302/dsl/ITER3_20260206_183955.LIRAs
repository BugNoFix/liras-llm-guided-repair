LabSamplesTransport

agents:
	humans: Nurse, LabPersonnel
	robots: Carrier, Arm

locations: PatientFloor, Laboratory, EntryModule

resources: Sample

Nurse:
	1: stop until position(Carrier, PatientFloor)
	2: deliver Sample

Carrier:
	1: moveTo PatientFloor
	2: receiveFrom Nurse
	3: moveTo Laboratory
	4: deliver Sample

Arm:
	1-3: stop until position(Carrier, Laboratory)
	4: fetch Sample
	5: moveTo EntryModule
	6: leave Sample