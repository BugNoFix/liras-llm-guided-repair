SampleTransport

agents:
	humans: Nurse, LabPersonnel
	robots: Transporter, Arm
locations: PatientFloor, Laboratory
resources: Sample

Nurse:
	1: collectAndLogSample
	2: deliver Sample

Transporter:
	1: stop
	2: restart all if !possess(Nurse, Sample)
	3: moveTo PatientFloor
	4: receiveFrom Nurse
	5: moveTo Laboratory
	
Arm:
	1-4: stop
	5: restart all if !position(Transporter, Laboratory)
	6: fetch Sample
	7: scanSortAndLoad
	
LabPersonnel:
	1-4: stop
	5: restart all if !position(Transporter, Laboratory)
	6: fetch Sample

conclusion:
	success: possess(Arm, Sample) || possess(LabPersonnel, Sample)
	failure: possess(Transporter, Sample)