SampleTransport

agents:
	nurses: Nurse
	transporters: DeliveryRobot
	arms: RoboticArm
	personnel: LabPersonnel
locations: PatientFloor, Laboratory
resources: Sample

Nurse:
	1: collect(Sample)
	   enterData(TrackSystem)
	2: put(Sample)
	3-5: stop

DeliveryRobot:
	1: moveTo PatientFloor
	2: unlockDrawer
	   wait 
	   lockDrawer
	   startTimer
	3: moveTo Laboratory
	4: stopTimer
	   checkProtocol
	   unlockDrawer
	5: wait until !contains(Sample)

RoboticArm:
	1-3: stop
	4: wait
	5: skip if !available(RoboticArm)
	   pick(Sample)
	   scan(Barcode)
	   sort(Sample)
	   logData
	   load(EntryModule)

LabPersonnel:
	1-3: stop
	4: wait
	5: skip if available(RoboticArm)
	   pick(Sample)
	   logData