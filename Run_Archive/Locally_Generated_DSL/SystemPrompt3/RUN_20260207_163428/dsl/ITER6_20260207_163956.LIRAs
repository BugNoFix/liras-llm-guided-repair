LabSampleTransport

Pattern:
	agents: Nurse, LabPersonnel, TransportRobot, RoboticArm
	locations: PatientFloor, Laboratory, AnalysisMachine
	resources: Sample

Nurse:
	1: fetch Sample
	2: wait 1
	3: deliver Sample

TransportRobot:
	1: stop until possess(Nurse, Sample)
	2: moveTo PatientFloor
	3: fetch Sample
	4: moveTo Laboratory
	5: deliver Sample

RoboticArm:
	1: stop until possess(TransportRobot, Sample) && position(TransportRobot, Laboratory)
	2: fetch Sample
	3: scan
	4: moveTo AnalysisMachine
	5: deliver Sample