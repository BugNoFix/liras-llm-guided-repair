LabSampleTransport

Pattern
	agents: Nurse, LabPersonnel, TransportBot, RoboticArm
	locations: PatientFloor, Laboratory
	resources: Sample

Nurse:
	1: fetch Sample
	2: moveTo TransportBot
	3: stop until position(TransportBot, PatientFloor)
	4: deliver Sample

TransportBot:
	1: moveTo PatientFloor
	2: receiveFrom Nurse
	3: moveTo Laboratory
	4: stop until !possess(TransportBot, Sample)

RoboticArm:
	1: stop until possess(TransportBot, Sample) && position(TransportBot, Laboratory)
	2: fetch Sample
	3: leave Sample