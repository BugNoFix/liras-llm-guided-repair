LabDelivery

agents:
	humans: Nurse, LabPersonnel
	robots: TransportBot, ArmBot
locations: PatientFloor, Laboratory
resources: Sample

Nurse:
	1: insertData
	   requestDelivery
	2: moveTo TransportBot
	3: deliver Sample

TransportBot:
	1: stop 
	   restart if !requested
	2: moveTo PatientFloor
	3: unlockDrawer if position(TransportBot, PatientFloor)
	   receiveFrom Nurse
	   lockDrawer
	4: moveTo Laboratory
	   checkTimeProtocol
	5: unlockDrawer if position(TransportBot, Laboratory)

ArmBot:
	1-4: stop
	5: fetch Sample
	6: scanBarcode
	   sort
	7: loadToEntryModule
	   logSecurely
