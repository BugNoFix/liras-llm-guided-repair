LabSampleTransport

agents:
	humans: Nurse, LabPersonnel
	robots: TransportRobot, RoboticArm
locations: PatientFloors, Laboratory, AnalysisMachine
resources: Sample

Nurse:
	1: fetch Sample
	2: moveTo TransportRobot
	3: deliver Sample

TransportRobot:
	1: moveTo PatientFloors
	2: receiveFrom Nurse
	3: moveTo Laboratory
	4: stop wait 5
	5: stop until !possess(TransportRobot, Sample)

RoboticArm:
	1: stop until possess(TransportRobot, Sample)
	2: receiveFrom TransportRobot
	3: stop wait 3
	4: moveTo AnalysisMachine
	5: deliver Sample
