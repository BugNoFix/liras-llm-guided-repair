LabSampleTransport

agents: Nurse, Transporter, Arm
locations: PatientFloor, Laboratory, AnalysisMachine
resources: Sample

Nurse:
	1: fetch Sample
	2: deliver Sample

Transporter:
	1: moveTo PatientFloor
	2: receiveFrom Nurse
	3: moveTo Laboratory
	4: deliver Sample

Arm:
	1: stop until dist(Transporter, Arm) < 2
	2: receiveFrom Transporter
	3: moveTo AnalysisMachine
	4: deliver Sample

failure: time(100)