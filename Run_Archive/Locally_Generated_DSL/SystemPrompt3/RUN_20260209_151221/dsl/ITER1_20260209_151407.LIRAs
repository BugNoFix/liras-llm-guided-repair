LabSampleTransport

agents:
	humans: Nurse, LabPersonnel
	robots: TransportBot, ArmBot
locations: PatientFloor, Laboratory, AnalysisMachine
resources: Sample

Nurse:
	1: pick Sample
	2: moveTo TransportBot
	3: deliver Sample

TransportBot:
	1: stop
	2: moveTo PatientFloor
	3: receiveFrom Nurse
	4: moveTo Laboratory
	5: stop

ArmBot:
	1-4: stop
	5: moveTo TransportBot
	   pick Sample
	6: moveTo AnalysisMachine
	   deposit Sample