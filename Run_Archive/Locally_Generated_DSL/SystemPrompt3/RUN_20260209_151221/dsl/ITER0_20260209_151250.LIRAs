LabSampleTransport

agents:
	humans: Nurse, LabPersonnel
	robots: TransportBot, ArmBot
locations: PatientFloor, Laboratory, AnalysisMachine
resources: Sample

Nurse:
	1: collect
	   inputData
	2: moveTo TransportBot
	3: deliver Sample
	   logStartTime

TransportBot:
	1: stop
	   restart if !called
	2: moveTo PatientFloor
	3: receiveFrom Nurse
	   lockDrawer
	4: moveTo Laboratory
	5: stop

ArmBot:
	1-4: stop
	5: moveTo TransportBot
	   unlockDrawer
	   fetch Sample
	6: scanBarcode
	   logEndTime
	7: moveTo AnalysisMachine
	   leave Sample